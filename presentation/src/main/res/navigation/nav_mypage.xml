<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_mypage"
    app:startDestination="@id/mypageFragment"
    >


    <fragment
        android:id="@+id/mypageFragment"
        android:name="com.umc.presentation.ui.mypage.MypageFragment"
        android:label="마이페이지"
        tools:layout="@layout/fragment_mypage"
        >

        <action
            android:id="@+id/action_mypage_to_profile"
            app:destination="@id/ProfileFragment"/>


        <action
            android:id="@+id/action_mypage_to_mypost"
            app:destination="@id/MypostFragment"/>




    </fragment>

    <fragment
        android:id="@+id/ProfileFragment"
        android:name="com.umc.presentation.ui.mypage.profile.ProfileFragment"
        android:label="프로필 수정"
        tools:layout="@layout/fragment_profile"
        >

    </fragment>

    <fragment
        android:id="@+id/MypostFragment"
        android:name="com.umc.presentation.ui.mypage.mypost.MypostFragment"
        android:label="나와 관련된 글"
        tools:layout="@layout/fragment_mypost"
        >

        <argument
            android:name="showType"
            app:argType="string"
            android:defaultValue="EMPTY" />

    </fragment>




</navigation>