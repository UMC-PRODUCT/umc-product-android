<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.umc.presentation.ui.notice.write.NoticeWriteViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral200"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_bar" />

        <LinearLayout
            android:id="@+id/layout_bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/image_camera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:onClick="@{()->vm.onClickCamera()}"
                android:src="@drawable/ic_camera"
                android:tint="@color/neutral600"
                tools:ignore="UseAppTint" />

            <ImageView
                android:id="@+id/image_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:onClick="@{()->vm.onClickShowLink(true)}"
                android:src="@drawable/ic_blog_link"
                android:tint="@color/neutral600"
                tools:ignore="UseAppTint" />

            <ImageView
                android:id="@+id/image_vote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:onClick="@{()->vm.onClickShowVote(true)}"
                android:src="@drawable/ic_vote"
                android:tint="@color/neutral600"
                tools:ignore="UseAppTint" />

            <ImageView
                android:id="@+id/image_check"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:src="@drawable/ic_check_box"
                tools:ignore="UseAppTint" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notice_write_sent_notification"
                android:textAppearance="@style/Subheadline"
                android:textColor="@color/neutral800" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <com.umc.presentation.component.UButton
                android:id="@+id/ubutton_complete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/primary500"
                app:contentPaddingBottom="13dp"
                app:contentPaddingLeft="16dp"
                app:contentPaddingRight="16dp"
                app:contentPaddingTop="13dp"
                app:cornerRadius="8dp"
                app:text="@string/notice_write_complete"
                app:textAppearance="@style/HeadlineBold"
                app:textColor="@color/neutral000" />

        </LinearLayout>


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_bar"
            app:layout_constraintTop_toTopOf="parent">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="43dp">


                <ImageView
                    android:id="@+id/image_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="8dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_back"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/neutral800" />

                <TextView
                    android:id="@+id/text_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/notice_write_title"
                    android:textAppearance="@style/Title2Bold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintBottom_toBottomOf="@id/image_back"
                    app:layout_constraintStart_toEndOf="@id/image_back"
                    app:layout_constraintTop_toTopOf="@id/image_back" />

                <TextView
                    android:id="@+id/text_category_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/notice_write_category_title"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_title" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_category"
                    android:layout_width="170dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                    android:onClick="@{()->vm.onClickShowDropDown()}"
                    android:paddingVertical="8dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_category_title">

                    <TextView
                        android:id="@+id/text_school"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@{vm.uiState.category.label}"
                        android:textAppearance="@style/CalloutBold"
                        android:textColor="@color/neutral800"
                        android:textColorHint="@color/neutral300"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_dropdown"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_dropdown"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_rect_neutral000_radius12"
                    android:paddingVertical="8dp"
                    android:translationZ="8dp"
                    android:visibility="@{vm.uiState.showDropDown ? View.VISIBLE : View.GONE}"
                    app:layout_constraintEnd_toEndOf="@id/layout_category"
                    app:layout_constraintStart_toStartOf="@id/layout_category"
                    app:layout_constraintTop_toBottomOf="@id/layout_category" />


                <TextView
                    android:id="@+id/text_class_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:text="@string/notice_write_class_title"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_category" />

                <TextView
                    android:id="@+id/text_class_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/notice_write_class_hint"
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintBottom_toBottomOf="@id/text_class_title"
                    app:layout_constraintStart_toEndOf="@id/text_class_title"
                    app:layout_constraintTop_toTopOf="@id/text_class_title" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_class"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:overScrollMode="never"
                    app:layout_constraintTop_toBottomOf="@id/text_class_title" />

                <TextView
                    android:id="@+id/text_part_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="32dp"
                    android:text="@string/notice_write_part_title"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    android:visibility="@{vm.uiState.showPartChip ? View.VISIBLE : View.GONE}"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/recycler_class" />

                <TextView
                    android:id="@+id/text_part_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/notice_write_part_hint"
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    android:visibility="@{vm.uiState.showPartChip ? View.VISIBLE : View.GONE}"
                    app:layout_constraintBottom_toBottomOf="@id/text_part_title"
                    app:layout_constraintStart_toEndOf="@id/text_part_title"
                    app:layout_constraintTop_toTopOf="@id/text_part_title" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_part"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:overScrollMode="never"
                    android:visibility="@{vm.uiState.showPartChip ? View.VISIBLE : View.GONE}"
                    app:layout_constraintTop_toBottomOf="@id/text_part_title" />

                <EditText
                    android:id="@+id/edit_text_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="32dp"
                    android:background="@null"
                    android:hint="@string/suggest_write_anomy_title_placeholder"
                    android:paddingVertical="16dp"
                    android:textAppearance="@style/Title3Bold"
                    android:textColor="@color/neutral800"
                    android:textColorHint="@color/neutral400"
                    app:layout_constraintTop_toBottomOf="@id/recycler_part" />

                <View
                    android:id="@+id/view_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="24dp"
                    android:background="@color/neutral200"
                    app:layout_constraintTop_toBottomOf="@id/edit_text_title" />

                <EditText
                    android:id="@+id/edit_text_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:background="@null"
                    android:hint="@string/suggest_write_anomy_content_placeholder"
                    android:paddingVertical="16dp"
                    android:textAppearance="@style/Body"
                    android:textColor="@color/neutral800"
                    android:textColorHint="@color/neutral400"
                    app:layout_constraintTop_toBottomOf="@id/view_divider" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_image"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:visibility="@{vm.uiState.selectImageList.empty ? View.GONE : View.VISIBLE}"
                    android:paddingTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/edit_text_content" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_link"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="@{vm.uiState.showLink ? View.VISIBLE : View.GONE}"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_rect_neutral100_radius12"
                    android:padding="16dp"
                    app:layout_constraintTop_toBottomOf="@id/recycler_image">

                    <ImageView
                        android:id="@+id/image_link_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:src="@drawable/ic_blog_link"
                        android:tint="@color/primary500"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/notice_write_link_title"
                        android:textAppearance="@style/HeadlineBold"
                        android:textColor="@color/neutral800"
                        app:layout_constraintBottom_toBottomOf="@id/image_link_title"
                        app:layout_constraintStart_toEndOf="@id/image_link_title"
                        app:layout_constraintTop_toTopOf="@id/image_link_title" />

                    <ImageView
                        android:id="@+id/image_delete_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:onClick="@{()->vm.onClickShowLink(false)}"
                        android:src="@drawable/ic_close_big"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.umc.presentation.component.UTextField
                        android:id="@+id/text_field_link"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/image_delete_link"
                        app:placeholderText="@string/notice_write_link_hint"
                        app:strokeColor="@color/neutral300"
                        app:strokeWidth="1dp"
                        app:textAppearance="@style/Body" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_vote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:visibility="@{vm.uiState.showVote ? View.VISIBLE : View.GONE}"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_rect_neutral100_radius12"
                    android:padding="16dp"
                    app:layout_constraintTop_toBottomOf="@id/layout_link">

                    <ImageView
                        android:id="@+id/image_vote_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:src="@drawable/ic_vote"
                        android:tint="@color/primary500"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:ignore="UseAppTint" />

                    <EditText
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:text="@string/notice_write_vote_title"
                        android:textAppearance="@style/HeadlineBold"
                        android:textColor="@color/neutral800"
                        app:layout_constraintBottom_toBottomOf="@id/image_vote_title"
                        app:layout_constraintStart_toEndOf="@id/image_vote_title"
                        app:layout_constraintTop_toTopOf="@id/image_vote_title" />

                    <ImageView
                        android:id="@+id/image_delete_vote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:onClick="@{()->vm.onClickShowVote(false)}"
                        android:src="@drawable/ic_close_big"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_vote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="16dp"
                        app:layout_constraintTop_toBottomOf="@id/image_delete_vote" />

                    <com.umc.presentation.component.UButton
                        android:id="@+id/ubutton_add_vote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:borderColor="@color/neutral300"
                        app:borderWidth="1dp"
                        app:cardBackgroundColor="@color/neutral000"
                        app:contentPaddingBottom="13dp"
                        app:contentPaddingTop="13dp"
                        app:cornerRadius="8dp"
                        app:layout_constraintTop_toBottomOf="@id/recycler_vote"
                        app:text="@string/notice_write_vote_add"
                        app:textAppearance="@style/CalloutBold"
                        app:textColor="@color/neutral800" />

                    <ImageView
                        android:id="@+id/image_check_select_mult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:padding="4dp"
                        android:src="@drawable/ic_check_box_empty"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ubutton_add_vote" />

                    <TextView
                        android:id="@+id/text_select_multiple"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notice_write_select_multiple"
                        android:textAppearance="@style/Footnote"
                        android:textColor="@color/neutral600"
                        app:layout_constraintBottom_toBottomOf="@id/image_check_select_mult"
                        app:layout_constraintEnd_toStartOf="@id/image_check_select_mult"
                        app:layout_constraintTop_toTopOf="@id/image_check_select_mult" />

                    <ImageView
                        android:id="@+id/image_check_anonymity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:padding="4dp"
                        android:src="@drawable/ic_check_box_empty"
                        app:layout_constraintEnd_toStartOf="@id/text_select_multiple"
                        app:layout_constraintTop_toBottomOf="@id/ubutton_add_vote" />

                    <TextView
                        android:id="@+id/text_select_anonymity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/notice_write_anonymity"
                        android:textAppearance="@style/Footnote"
                        android:textColor="@color/neutral600"
                        app:layout_constraintBottom_toBottomOf="@id/image_check_anonymity"
                        app:layout_constraintEnd_toStartOf="@id/image_check_anonymity"
                        app:layout_constraintTop_toTopOf="@id/image_check_anonymity" />

                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>

