<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.umc.presentation.ui.act.challenge.AdminChallengerDetailViewModel" />

        <variable
            name="state"
            type="com.umc.presentation.ui.act.challenge.AdminChallengerDetailUiState" />

        <variable
            name="model"
            type="com.umc.domain.model.act.challenger.ChallengerManageDialogModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral100">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:overScrollMode="never"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_top_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/neutral000"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:id="@+id/layout_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/btn_back"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_back" />

                        <TextView
                            android:id="@+id/tv_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="프로필 상세 보기"
                            android:textAppearance="@style/Title3Bold"
                            android:textColor="@color/neutral900" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_profile_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imv_profile"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginTop="10dp"
                            app:profileImageUrl="@{model.profileImageUrl}"
                            app:shapeAppearanceOverlay="@style/CircleImageAppearance"
                            app:strokeColor="@color/neutral200"
                            app:strokeWidth="1dp" />

                        <LinearLayout
                            android:id="@+id/layout_name_row"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:text='@{model.nickname != null &amp;&amp; !model.nickname.isEmpty() ? model.nickname + "(" + model.name + ")" : model.name}'
                                android:textAppearance="@style/Title3Bold"
                                android:textColor="@color/neutral900"
                                tools:text="닉네임(이름)" />

                            <TextView
                                android:id="@+id/tv_gisu_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                app:text='@{String.valueOf(model.gisu)}'
                                android:textAppearance="@style/Subheadline"
                                android:textColor="@color/neutral500" />

                            <com.umc.presentation.component.UButton
                                android:id="@+id/btn_generation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:clickable="false"
                                app:borderColor="@color/transparent"
                                app:borderWidth="0dp"
                                app:cardBackgroundColor="@color/accent100"
                                app:contentPaddingLeft="8dp"
                                app:contentPaddingTop="3dp"
                                app:contentPaddingRight="8dp"
                                app:contentPaddingBottom="3dp"
                                app:cornerRadius="6dp"
                                app:text='@{model.university}'
                                tools:text="중앙대학교"
                                app:textAppearance="@style/Caption1Bold"
                                app:textColor="@color/accent500"
                                 />

                            <com.umc.presentation.component.UButton
                                android:id="@+id/btn_part"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:clickable="false"
                                app:borderColor="@color/transparent"
                                app:borderWidth="0dp"
                                app:cardBackgroundColor="@color/primary100"
                                app:contentPaddingLeft="8dp"
                                app:contentPaddingTop="3dp"
                                app:contentPaddingRight="8dp"
                                app:contentPaddingBottom="3dp"
                                app:cornerRadius="6dp"
                                app:text='@{model.part}'
                                app:textAppearance="@style/Caption1Bold"
                                app:textColor="@color/primary500"
                                tools:text="Web" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_score_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_neutral100_radius8"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp"
                            android:text='@{model.name + "님의 총점수는 " + String.valueOf((int)model.totalScore) + "점입니다."}'
                            android:textAppearance="@style/HeadlineBold"
                            android:textColor="@color/neutral800"
                            tools:text="홍길동님의 총점수는 0점입니다." />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_action_buttons"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/layout_add_positive"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:id="@+id/iv_positive"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_circle_success100"
                                android:padding="8dp"
                                android:src="@drawable/ic_add_filled"
                                app:tint="@color/success500"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>

                            <TextView
                                android:id="@+id/tv_positive"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="상점 부여하기"
                                android:textAppearance="@style/HeadlineBold"
                                android:textColor="@color/neutral800"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toEndOf="@id/iv_positive"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/iv_positive_arrow"
                                android:layout_width="12dp"
                                android:layout_height="9dp"
                                android:src="@drawable/ic_arrow_next"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/neutral400" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/layout_add_negative"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:id="@+id/iv_negative"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_circle_danger100"
                                android:padding="8dp"
                                android:src="@drawable/ic_minus_circle_red"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>

                            <TextView
                                android:id="@+id/tv_negative"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="벌점 부여하기"
                                android:textAppearance="@style/HeadlineBold"
                                android:textColor="@color/neutral800"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toEndOf="@id/iv_negative"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/iv_negative_arrow"
                                android:layout_width="12dp"
                                android:layout_height="9dp"
                                android:src="@drawable/ic_arrow_next"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/neutral400" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/layout_add_etc"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:id="@+id/iv_etc"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_circle_neutral100"
                                android:padding="8dp"
                                android:src="@drawable/ic_warning"
                                app:tint="@color/neutral500"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>

                            <TextView
                                android:id="@+id/tv_etc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:text="기타 상벌점 부여하기"
                                android:textAppearance="@style/HeadlineBold"
                                android:textColor="@color/neutral800"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toEndOf="@id/iv_etc"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/iv_etc_arrow"
                                android:layout_width="12dp"
                                android:layout_height="9dp"
                                android:src="@drawable/ic_arrow_next"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/neutral400" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>

                </LinearLayout>


                <View
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />


                <LinearLayout
                    android:id="@+id/layout_history_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/neutral000"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:id="@+id/layout_history_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_history"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_history"
                            app:tint="@color/neutral600" />

                        <TextView
                            android:id="@+id/tv_history_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="히스토리"
                            android:textAppearance="@style/Title3Bold"
                            android:textColor="@color/neutral900" />

                        <com.umc.presentation.component.UButton
                            android:id="@+id/btn_positive_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:clickable="false"
                            app:borderColor="@color/transparent"
                            app:borderWidth="0dp"
                            app:cardBackgroundColor="@color/success100"
                            app:contentPaddingLeft="6dp"
                            app:contentPaddingTop="2dp"
                            app:contentPaddingRight="6dp"
                            app:contentPaddingBottom="2dp"
                            app:cornerRadius="4dp"
                            app:text='@{"상점 " + model.positiveCount}'
                            app:textAppearance="@style/Caption2Bold"
                            app:textColor="@color/success500"
                            tools:text="상점 1" />

                        <com.umc.presentation.component.UButton
                            android:id="@+id/btn_negative_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:clickable="false"
                            app:borderColor="@color/transparent"
                            app:borderWidth="0dp"
                            app:cardBackgroundColor="@color/danger100"
                            app:contentPaddingLeft="6dp"
                            app:contentPaddingTop="2dp"
                            app:contentPaddingRight="6dp"
                            app:contentPaddingBottom="2dp"
                            app:cornerRadius="4dp"
                            app:text='@{"벌점 " + model.warningCount}'
                            app:textAppearance="@style/Caption2Bold"
                            app:textColor="@color/danger500"
                            tools:text="벌점 1" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:padding="12dp"
                        android:visibility="@{model.history.empty ? View.GONE : View.VISIBLE}"
                        tools:listitem="@layout/item_challenger_history" />

                    <LinearLayout
                        android:id="@+id/layout_empty_history"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="30dp"
                        android:visibility="@{model.history.empty ? View.VISIBLE : View.GONE}">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_history"
                            app:tint="@color/neutral500" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="아직 활동 기록이 없습니다"
                            android:textAppearance="@style/Caption1Bold"
                            android:textColor="@color/neutral500" />
                    </LinearLayout>

                    <com.umc.presentation.component.UButton
                        android:id="@+id/btn_edit_history_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        app:borderColor="@color/transparent"
                        app:borderWidth="0dp"
                        app:cardBackgroundColor="@color/neutral100"
                        app:contentPaddingLeft="14dp"
                        app:contentPaddingTop="8dp"
                        app:contentPaddingRight="14dp"
                        app:contentPaddingBottom="8dp"
                        app:text="기록 수정하기"
                        app:textAppearance="@style/Caption1Bold"
                        app:textColor="@color/neutral500"
                        app:prevIcon="@drawable/ic_edit" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>