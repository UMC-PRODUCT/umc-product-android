<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.community.write.PostWriteFragment">

    <data>

        <import type="android.view.View"/>

        <variable
            name="vm"
            type="com.umc.presentation.ui.community.write.PostWriteViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:background="@color/neutral000"
        >

        <!-- 상단 바 -->
        <ImageView
            android:id="@+id/write_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:onClick="@{()->vm.onClickBackPressed()}"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/write_tv_title"
            app:layout_constraintBottom_toBottomOf="@id/write_tv_title"
            app:layout_constraintStart_toStartOf="parent"
            />

        <TextView
            android:id="@+id/write_tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Title2Bold"
            android:textColor="@color/neutral800"
            android:layout_marginStart="8dp"
            android:layout_marginTop="18dp"
            android:text="@string/community_write_title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/write_btn_back"
            />

        <TextView
            android:id="@+id/write_tv_complete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/CalloutBold"
            android:textColor="@color/primary500"
            android:clickable="true"
            android:text="@string/register"
            android:onClick="@{()->vm.createPost()}"
            app:layout_constraintTop_toTopOf="@id/write_tv_title"
            app:layout_constraintBottom_toBottomOf="@id/write_tv_title"
            app:layout_constraintEnd_toEndOf="parent"
            />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:isScrollContainer="true"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/write_tv_title"
        app:layout_constraintBottom_toBottomOf="parent"
        >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


        <!--카테고리-->
        <TextView
            android:id="@+id/write_tv_category"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textAppearance="@style/HeadlineBold"
            android:textColor="@color/neutral800"
            android:text="@string/community_write_category"
            android:layout_marginTop="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/write_cdv_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/neutral000"
            android:layout_marginTop="16dp"
            android:onClick="@{()->vm.onClickContentCategorySelect()}"
            app:cardBackgroundColor="@color/neutral000"
            app:strokeWidth="1dp"
            app:strokeColor="@color/neutral200"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/write_tv_category">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:paddingHorizontal="12dp">

                <TextView
                    android:id="@+id/write_tv_category_select"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:textAppearance="@style/CalloutBold"
                    android:textColor="@color/neutral500"
                    android:text="@{vm.uiState.selectCommunityCategory.label}"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    />

                <ImageView
                    android:id="@+id/write_imv_dropdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_dropdown"
                    android:layout_marginStart="4dp"
                    android:tint="@color/neutral400"
                    app:layout_constraintStart_toEndOf="@id/write_tv_category_select"
                    app:layout_constraintTop_toTopOf="@id/write_tv_category_select"
                    app:layout_constraintBottom_toBottomOf="@id/write_tv_category_select"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


        <!--editText 탭-->

        <EditText
            android:id="@+id/write_textfield_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@null"
            android:hint="@string/suggest_write_anomy_title_placeholder"
            android:paddingVertical="16dp"
            android:singleLine="true"
            android:textAppearance="@style/Title3Bold"
            android:textColor="@color/neutral800"
            android:textColorHint="@color/neutral400"
            app:layout_constraintTop_toBottomOf="@id/write_cdv_category" />

        <View
            android:id="@+id/write_view_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral400"
            app:layout_constraintTop_toBottomOf="@id/write_textfield_title" />

        <EditText
            android:id="@+id/write_textfield_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@null"
            android:gravity="top"
            android:hint="@string/suggest_write_anomy_content_placeholder"
            android:inputType="textMultiLine"
            android:paddingVertical="16dp"
            android:layout_marginBottom="64dp"
            android:textAppearance="@style/Body"
            android:textColor="@color/neutral800"
            android:textColorHint="@color/neutral400"
            app:layout_constraintTop_toBottomOf="@id/write_view_divider" />


        <!-- 번개함-->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/write_cdv_light"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:background="@color/neutral000"
            android:visibility="@{vm.uiState.isLight ? View.VISIBLE : View.GONE}"
            app:cardBackgroundColor="@color/neutral000"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/warning500"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/write_textfield_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="24dp"
            >

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/write_guideline_divide1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.5"/>

            <!--TODO 변경-->
            <ImageView
                android:id="@+id/write_imv_light"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_lightning"
                app:tint="@color/warning500"
                />

            <TextView
                android:id="@+id/write_tv_light_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:textAppearance="@style/HeadlineBold"
                android:textColor="@color/warning500"
                android:text="@string/community_write_light_title"
                android:layout_marginStart="4dp"
                app:layout_constraintStart_toEndOf="@id/write_imv_light"
                app:layout_constraintTop_toTopOf="@id/write_imv_light"
                app:layout_constraintBottom_toBottomOf="@id/write_imv_light"
                />

            <!--날짜/시간-->
            <TextView
                android:id="@+id/write_tv_light_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="@style/SubheadlineBold"
                android:gravity="start"
                android:textColor="@color/neutral800"
                android:layout_marginTop="24dp"
                android:text="@string/community_write_light_time"
                android:layout_marginEnd="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/write_guideline_divide1"
                app:layout_constraintTop_toBottomOf="@id/write_tv_light_title"
                />

            <com.umc.presentation.component.UTextField
                android:id="@+id/write_textfield_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/neutral000"
                app:strokeColor="@color/neutral300"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/neutral000"
                android:layout_marginEnd="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/write_guideline_divide1"
                app:layout_constraintTop_toBottomOf="@id/write_tv_light_time"
                app:placeholderText="@string/community_write_light_time_placeholder"
                android:focusable="false"
                app:textAppearance="@style/Body"
                app:imeAction="@{android.view.inputmethod.EditorInfo.IME_ACTION_DONE}"
                />

            <!--최대 인원-->
            <TextView
                android:id="@+id/write_tv_light_people"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="@style/SubheadlineBold"
                android:gravity="start"
                android:textColor="@color/neutral800"
                android:layout_marginTop="24dp"
                android:text="@string/community_write_light_people"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toEndOf="@id/write_guideline_divide1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/write_tv_light_title"
                />

            <com.umc.presentation.component.UTextField
                android:id="@+id/write_textfield_people"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/neutral000"
                app:strokeColor="@color/neutral300"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/neutral000"
                android:layout_marginStart="8dp"
                android:inputType="number"
                app:layout_constraintStart_toEndOf="@id/write_guideline_divide1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/write_tv_light_people"
                app:placeholderText="@string/community_write_light_people_placeholder"
                app:textAppearance="@style/Body"
                app:imeAction="@{android.view.inputmethod.EditorInfo.IME_ACTION_DONE}"
                />

            <!--장소-->
            <TextView
                android:id="@+id/write_tv_light_place"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="@style/SubheadlineBold"
                android:gravity="start"
                android:textColor="@color/neutral800"
                android:layout_marginTop="24dp"
                android:text="@string/community_write_light_place"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/write_textfield_time"
                />

            <com.umc.presentation.component.UTextField
                android:id="@+id/write_textfield_place"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/neutral000"
                app:strokeColor="@color/neutral300"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/neutral000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/write_tv_light_place"
                app:placeholderText="@string/community_write_light_place_placeholder"
                app:textAppearance="@style/Body"
                app:imeAction="@{android.view.inputmethod.EditorInfo.IME_ACTION_DONE}"
                />

            <!--오픈챗-->
            <TextView
                android:id="@+id/write_tv_light_openchat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textAppearance="@style/SubheadlineBold"
                android:gravity="start"
                android:textColor="@color/neutral800"
                android:layout_marginTop="24dp"
                android:text="@string/community_write_light_openchat"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/write_textfield_place"
                />

            <com.umc.presentation.component.UTextField
                android:id="@+id/write_textfield_openchat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/neutral000"
                app:backgroundColor="@{vm.uiState.isOpenChatValid ? @color/neutral000 : @color/danger100}"
                app:strokeColor="@{vm.uiState.isOpenChatValid ? @color/neutral300 : @color/danger500}"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/neutral000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/write_tv_light_openchat"
                app:placeholderText="@string/community_write_light_openchat_placeholder"
                app:textAppearance="@style/Body"
                app:textColor="@{vm.uiState.isOpenChatValid ? @color/neutral800 : @color/danger500}"
                app:imeAction="@{android.view.inputmethod.EditorInfo.IME_ACTION_DONE}"
                />

            <TextView
                android:id="@+id/write_tv_light_openchat_error"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/community_write_light_openchat_error"
                android:textAppearance="@style/Footnote"
                android:textColor="@color/danger500"
                android:visibility="@{vm.uiState.isOpenChatValid ? View.GONE : View.VISIBLE}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/write_textfield_openchat" />


        </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>