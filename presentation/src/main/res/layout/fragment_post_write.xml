<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.community.write.PostWriteFragment">

    <data>

        <variable
            name="vm"
            type="com.umc.presentation.ui.community.write.PostWriteViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp"
        android:background="@color/neutral000"
        >

        <!-- 상단 바 -->
        <ImageView
            android:id="@+id/write_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:onClick="@{()->vm.onClickBackPressed()}"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/write_tv_title"
            app:layout_constraintBottom_toBottomOf="@id/write_tv_title"
            app:layout_constraintStart_toStartOf="parent"
            />

        <TextView
            android:id="@+id/write_tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Title2Bold"
            android:textColor="@color/neutral800"
            android:layout_marginStart="8dp"
            android:layout_marginTop="18dp"
            android:text="@string/community_write_title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/write_btn_back"
            />

        <TextView
            android:id="@+id/write_tv_complete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/CalloutBold"
            android:textColor="@color/primary500"
            android:clickable="true"
            android:text="@string/register"
            app:layout_constraintTop_toTopOf="@id/write_tv_title"
            app:layout_constraintBottom_toBottomOf="@id/write_tv_title"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <!--카테고리-->
        <TextView
            android:id="@+id/write_tv_category"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textAppearance="@style/HeadlineBold"
            android:textColor="@color/neutral800"
            android:text="@string/community_write_category"
            android:layout_marginTop="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/write_tv_title"
            />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/write_cdv_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/neutral000"
            android:layout_marginTop="16dp"
            android:onClick="@{()->vm.onClickContentCategorySelect()}"
            app:cardBackgroundColor="@color/neutral000"
            app:strokeWidth="1dp"
            app:strokeColor="@color/neutral200"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/write_tv_category">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:paddingHorizontal="12dp">

                <TextView
                    android:id="@+id/write_tv_category_select"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:textAppearance="@style/CalloutBold"
                    android:textColor="@color/neutral500"
                    android:text="@{vm.uiState.selectContentCategory.name}"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    />

                <ImageView
                    android:id="@+id/write_imv_dropdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_dropdown"
                    android:layout_marginStart="4dp"
                    android:tint="@color/neutral400"
                    app:layout_constraintStart_toEndOf="@id/write_tv_category_select"
                    app:layout_constraintTop_toTopOf="@id/write_tv_category_select"
                    app:layout_constraintBottom_toBottomOf="@id/write_tv_category_select"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


        <!--지역 탭-->

        <TextView
            android:id="@+id/write_tv_region"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textAppearance="@style/HeadlineBold"
            android:textColor="@color/neutral800"
            android:text="@string/region"
            android:layout_marginTop="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/write_cdv_category"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/write_rcv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/write_tv_region"
            tools:listitem="@layout/item_home_category"
            />

        <!--editText 탭-->

        <EditText
            android:id="@+id/write_textfield_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@null"
            android:hint="@string/suggest_write_anomy_title_placeholder"
            android:paddingVertical="16dp"
            android:singleLine="true"
            android:textAppearance="@style/Title3Bold"
            android:textColor="@color/neutral800"
            android:textColorHint="@color/neutral400"
            app:layout_constraintTop_toBottomOf="@id/write_rcv" />

        <View
            android:id="@+id/write_view_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral400"
            app:layout_constraintTop_toBottomOf="@id/write_textfield_title" />

        <EditText
            android:id="@+id/write_textfield_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:background="@null"
            android:gravity="top"
            android:hint="@string/suggest_write_anomy_content_placeholder"
            android:inputType="textMultiLine"
            android:paddingVertical="16dp"
            android:layout_marginBottom="64dp"
            android:textAppearance="@style/Body"
            android:textColor="@color/neutral800"
            android:textColorHint="@color/neutral400"
            app:layout_constraintTop_toBottomOf="@id/write_view_divider"
            app:layout_constraintBottom_toBottomOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>