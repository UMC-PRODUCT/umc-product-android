<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.umc.presentation.component.UTextField
            android:id="@+id/text_field_vote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            app:layout_constraintTop_toTopOf="parent"
            app:placeholderText="@string/notice_write_link_hint"
            app:strokeColor="@color/neutral300"
            app:strokeWidth="1dp"
            app:textAppearance="@style/Body" />

        <ImageView
            android:id="@+id/image_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:src="@drawable/ic_delete_filled" />
    </LinearLayout>

</layout>