<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="vm"
            type="com.umc.presentation.ui.act.study.submit.model.AdminActStudySubmitViewModel" />
        <variable
            name="state"
            type="com.umc.presentation.ui.act.study.submit.model.AdminActStudySubmitState" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral000"
        >

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_filter_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/neutral000"
            app:strokeColor="@color/neutral200"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_neutral100_radius8"
                android:paddingHorizontal="12dp"
                >

                <ImageView
                    android:id="@+id/iv_filter"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/neutral600"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/tv_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="필터링"
                    android:textAppearance="@style/FootnoteBold"
                    android:textColor="@color/neutral700"
                    app:layout_constraintStart_toEndOf="@id/iv_filter"
                    app:layout_constraintTop_toTopOf="@id/iv_filter"
                    app:layout_constraintBottom_toBottomOf="@id/iv_filter" />



                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_group_dropdown"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_neutral000_radius8"
                    android:paddingHorizontal="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/tv_group"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='@{vm.getSelectedGroupName(state)}'
                        android:textAppearance="@style/Caption1Bold"
                        android:textColor="@color/neutral700"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <ImageView
                        android:id="@+id/iv_group_arrow"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_dropdown_down"
                        app:tint="@color/neutral500"
                        app:layout_constraintStart_toEndOf="@id/tv_group"
                        app:layout_constraintTop_toTopOf="@id/tv_group"
                        app:layout_constraintBottom_toBottomOf="@id/tv_group"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>


                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_week_dropdown"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_neutral000_radius8"
                    android:paddingHorizontal="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintEnd_toStartOf="@id/cl_group_dropdown"
                    app:layout_constraintTop_toTopOf="@id/cl_group_dropdown"
                    app:layout_constraintBottom_toBottomOf="@id/cl_group_dropdown">

                    <TextView
                        android:id="@+id/tv_week"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='@{state.selectedWeek + "주차"}'
                        android:textAppearance="@style/Caption1Bold"
                        android:textColor="@color/neutral700"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"/>

                    <ImageView
                        android:id="@+id/iv_week_arrow"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_dropdown_down"
                        app:tint="@color/neutral500"
                        app:layout_constraintStart_toEndOf="@id/tv_week"
                        app:layout_constraintTop_toTopOf="@id/tv_week"
                        app:layout_constraintBottom_toBottomOf="@id/tv_week"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>




        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_submit"
            android:background="@color/neutral100"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/card_filter_container"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_act_admin_study_submit" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="제출 내역이 없어요"
            android:textAppearance="@style/FootnoteBold"
            android:textColor="@color/neutral500"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="@id/rv_submit"
            app:layout_constraintBottom_toBottomOf="@id/rv_submit"
            app:layout_constraintStart_toStartOf="@id/rv_submit"
            app:layout_constraintEnd_toEndOf="@id/rv_submit" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
