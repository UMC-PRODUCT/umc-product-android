<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="vm"
            type="com.umc.presentation.ui.act.study.submit.AdminActStudySubmitViewModel" />
        <variable
            name="state"
            type="com.umc.presentation.ui.act.study.submit.AdminActStudySubmitState" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral000"
        >

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_filter_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/neutral000"
            app:strokeColor="@color/neutral200"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_neutral100_radius8"
                android:paddingHorizontal="12dp"
                >

                <ImageView
                    android:id="@+id/iv_filter"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_dropdown_down"
                    app:tint="@color/neutral600"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/tv_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="필터링"
                    android:textAppearance="@style/FootnoteBold"
                    android:textColor="@color/neutral700"
                    app:layout_constraintStart_toEndOf="@id/iv_filter"
                    app:layout_constraintTop_toTopOf="@id/iv_filter"
                    app:layout_constraintBottom_toBottomOf="@id/iv_filter" />


                <com.umc.presentation.component.UButton
                    android:id="@+id/ub_group"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:buttonElevation="0"
                    app:cornerRadius="6dp"
                    app:contentPaddingLeft="10dp"
                    app:contentPaddingRight="10dp"
                    app:contentPaddingTop="4dp"
                    app:contentPaddingBottom="4dp"
                    app:textAppearance="@style/Caption1Bold"
                    app:text='@{state.selectedGroupId == null ? "전체 그룹" : "선택 그룹"}'
                    app:backgroundColor="@color/neutral000"
                    app:borderWidth="1dp"
                    app:borderColor="@color/neutral200"
                    app:textColor="@color/neutral700"
                    app:rightIcon="@drawable/ic_dropdown_down"
                    app:rightIconTint="@color/neutral500"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    tools:text="전체 그룹" />


                <com.umc.presentation.component.UButton
                    android:id="@+id/ub_week"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:buttonElevation="0"
                    app:cornerRadius="6dp"
                    app:contentPaddingLeft="10dp"
                    app:contentPaddingRight="10dp"
                    app:contentPaddingTop="4dp"
                    app:contentPaddingBottom="4dp"
                    app:textAppearance="@style/Caption1Bold"
                    app:text='@{state.selectedWeek + "주차"}'
                    app:backgroundColor="@color/neutral000"
                    app:borderWidth="1dp"
                    app:borderColor="@color/neutral200"
                    app:textColor="@color/neutral700"
                    app:rightIcon="@drawable/ic_dropdown_down"
                    app:rightIconTint="@color/neutral500"
                    app:layout_constraintEnd_toStartOf="@id/ub_group"
                    app:layout_constraintTop_toTopOf="@id/ub_group"
                    app:layout_constraintBottom_toBottomOf="@id/ub_group"
                    tools:text="1주차" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>




        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_submit"
            android:background="@color/neutral100"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/card_filter_container"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_act_admin_study_submit" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
