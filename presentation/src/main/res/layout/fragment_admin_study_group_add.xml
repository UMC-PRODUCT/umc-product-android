<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.umc.presentation.ui.act.study.group.create.model.AdminStudyGroupAddViewModel" />

        <variable
            name="state"
            type="com.umc.presentation.ui.act.study.group.create.model.AdminStudyGroupAddState" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral000"
        android:paddingHorizontal="16dp">


        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/tv_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginStart="16dp"
            android:text="스터디 그룹 생성"
            android:textAppearance="@style/Title2Bold"
            android:textColor="@color/neutral800"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back" />

        <TextView
            android:id="@+id/btn_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="등록"
            android:textAppearance="@style/SubheadlineBold"
            android:textColor="@color/primary500"
            app:layout_constraintTop_toTopOf="@id/tv_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            app:layout_constraintEnd_toEndOf="parent" />


        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:fillViewport="true"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/tv_group_name_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="그룹 이름"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_group_name_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/danger500"
                    app:layout_constraintStart_toEndOf="@id/tv_group_name_label"
                    app:layout_constraintTop_toTopOf="@id/tv_group_name_label" />

                <com.umc.presentation.component.UTextField
                    android:id="@+id/et_group_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:strokeColor="@color/neutral300"
                    app:strokeWidth="1dp"
                    app:placeholderText="예: React 실습 A팀"
                    app:textAppearance="@style/Subheadline"
                    app:layout_constraintTop_toBottomOf="@id/tv_group_name_label"
                    app:layout_constraintStart_toStartOf="parent" />


                <TextView
                    android:id="@+id/tv_part_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="해당 파트"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_group_name" />

                <TextView
                    android:id="@+id/tv_part_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/danger500"
                    app:layout_constraintStart_toEndOf="@id/tv_part_label"
                    app:layout_constraintTop_toTopOf="@id/tv_part_label" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_part"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    android:background="@drawable/bg_neutral000_radius8"
                    app:strokeColor="@color/neutral300"
                    app:cardBackgroundColor="@color/neutral000"
                    app:layout_constraintTop_toBottomOf="@id/tv_part_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/tv_selected_part"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Web"
                            android:textAppearance="@style/Subheadline"
                            android:textColor="@color/neutral800"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/iv_part_arrow"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <ImageView
                            android:id="@+id/iv_part_arrow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_dropdown_down"
                            app:tint="@color/neutral400"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_part_dropdown"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/neutral200"
                    app:cardBackgroundColor="@color/neutral000"
                    app:layout_constraintTop_toBottomOf="@id/card_part"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_part_dropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        tools:listitem="@layout/item_dropdown" />

                </com.google.android.material.card.MaterialCardView>



                <TextView
                    android:id="@+id/tv_leader_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="담당 파트장"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/card_part" />

                <TextView
                    android:id="@+id/tv_leader_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/danger500"
                    app:layout_constraintStart_toEndOf="@id/tv_leader_label"
                    app:layout_constraintTop_toTopOf="@id/tv_leader_label" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_pick_leader"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/neutral300"
                    app:cardBackgroundColor="@color/neutral000"
                    app:layout_constraintTop_toBottomOf="@id/tv_leader_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/tv_leader_placeholder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="담당 파트장을 선택하세요"
                            android:textAppearance="@style/Subheadline"
                            android:textColor="@color/neutral400"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/iv_leader_arrow"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <ImageView
                            android:id="@+id/iv_leader_arrow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="@color/neutral400"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>


                <TextView
                    android:id="@+id/tv_members_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="스터디원 추가"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/card_pick_leader" />

                <TextView
                    android:id="@+id/tv_members_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/danger500"
                    app:layout_constraintStart_toEndOf="@id/tv_members_label"
                    app:layout_constraintTop_toTopOf="@id/tv_members_label" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_pick_members"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/neutral300"
                    app:cardBackgroundColor="@color/neutral000"
                    app:layout_constraintTop_toBottomOf="@id/tv_members_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingHorizontal="12dp">

                        <TextView
                            android:id="@+id/tv_members_placeholder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="스터디원을 선택하세요"
                            android:textAppearance="@style/Subheadline"
                            android:textColor="@color/neutral400"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/iv_members_arrow"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                        <ImageView
                            android:id="@+id/iv_members_arrow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_next"
                            app:tint="@color/neutral400"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>


                <View
                    android:layout_width="wrap_content"
                    android:layout_height="64dp"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/card_pick_members"
                    app:layout_constraintStart_toStartOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
