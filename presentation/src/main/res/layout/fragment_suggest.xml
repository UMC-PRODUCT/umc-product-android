<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.mypage.suggest.SuggestFragment">

    <data>

        <variable
            name="vm"
            type="com.umc.presentation.ui.mypage.suggest.SuggestViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="56dp"
        android:paddingBottom="64dp"
        android:paddingHorizontal="16dp"
        android:background="@color/neutral100"
        >

        <!-- 상단 바 -->
        <ImageView
            android:id="@+id/suggest_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/suggest_tv_title"
            app:layout_constraintBottom_toBottomOf="@id/suggest_tv_title"
            app:layout_constraintStart_toStartOf="parent"
            />

        <TextView
            android:id="@+id/suggest_tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Title2Bold"
            android:textColor="@color/neutral800"
            android:layout_marginStart="8dp"
            android:text="@string/suggest_title"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/suggest_btn_back"
            />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/suggest_cdv_question"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@color/primary100"
        app:cardBackgroundColor="@color/primary100"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/suggest_tv_title">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        >

        <TextView
            android:id="@+id/suggest_tv_ask_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textAppearance="@style/HeadlineBold"
            android:textColor="@color/primary600"
            android:text="@string/suggest_ask_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            />

        <TextView
            android:id="@+id/suggest_tv_ask_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:textAppearance="@style/Footnote"
            android:layout_marginTop="4dp"
            android:textColor="@color/neutral600"
            android:text="@string/suggest_ask_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/suggest_tv_ask_title"
            />

        <com.umc.presentation.component.UButton
            android:id="@+id/suggest_btn_go_write"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="@{()->vm.navigateSuggestWrite()}"
            app:cardBackgroundColor="@color/primary500"
            app:pressedColor="@color/primary700"
            app:borderWidth="0dp"
            app:text="@string/suggest_btn_content"
            app:textAppearance="@style/Caption1Bold"
            app:textColor="@color/neutral000"
            app:buttonElevation="0"
            app:contentPaddingBottom="4dp"
            app:contentPaddingTop="4dp"
            app:contentPaddingLeft="8dp"
            app:contentPaddingRight="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/suggest_rcv"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/suggest_cdv_question"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:listitem="@layout/item_mypage_content"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>