<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.view.View" />
        <variable
            name="model"
            type="com.umc.presentation.component.UMypageDialogModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neutral000_radius16"
        android:padding="24dp"
        >

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@{model.title}"
            android:gravity="start"
            android:textAppearance="@style/Title3Bold"
            android:textColor="@color/neutral800"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="제목입니다!"
            />

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="@{model.content == null ? View.GONE : View.VISIBLE}"
            android:text="@{model.content}"
            android:gravity="start"
            android:textAppearance="@style/Subheadline"
            android:textColor="@color/neutral600"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="내용입니다!"
            />

        <!--isTwoButton이 true일 경우 두개 다 보여주기-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:visibility="@{model.isTwoButton ? View.VISIBLE : View.GONE}"
            app:layout_constraintTop_toBottomOf="@id/tv_content"
            >

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_negative"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:contentPaddingBottom="13dp"
                app:contentPaddingTop="13dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingLeft="8dp"
                app:text="@{model.negativeText}"
                app:textColor="@color/neutral800"
                app:cardBackgroundColor="@color/neutral000"
                app:pressedColor="@color/neutral200"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp"
                />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_positive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:text="@{model.positiveText}"
                app:contentPaddingBottom="13dp"
                app:contentPaddingTop="13dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingLeft="8dp"
                app:cardBackgroundColor="@color/neutral000"
                app:pressedColor="@color/danger100"
                app:textColor='@color/danger500'
                app:borderColor='@color/danger500'
                app:borderWidth="1dp"
                />
        </LinearLayout>

        <com.umc.presentation.component.UButton
            android:id="@+id/btn_comfirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="24dp"
            android:visibility="@{model.isTwoButton ? View.GONE : View.VISIBLE}"
            app:contentPaddingBottom="13dp"
            app:contentPaddingTop="13dp"
            app:contentPaddingRight="8dp"
            app:contentPaddingLeft="8dp"
            app:text="@{model.confirmText}"
            app:textColor="@color/neutral800"
            app:cardBackgroundColor="@color/neutral000"
            app:pressedColor="@color/neutral200"
            app:borderColor="@color/neutral300"
            app:borderWidth="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_content"
            />



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>