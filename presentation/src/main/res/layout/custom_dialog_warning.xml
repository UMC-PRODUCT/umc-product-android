<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable
            name="model"
            type="com.umc.presentation.component.UBasicDialogModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neutral000_radius16"
        android:padding="24dp">

        <ImageView
            android:id="@+id/imv_icon_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_delete"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/imv_icon_warning"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_error_filled"
            android:background="@drawable/bg_danger100_radius8"
            app:tint="@color/danger500"
            app:layout_constraintTop_toBottomOf="@id/imv_icon_close"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@{model.title}"
            android:gravity="center"
            android:textAppearance="@style/Title3Bold"
            android:textColor="@color/neutral800"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/imv_icon_warning"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="제목입니다!"
            />

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:visibility="@{model.content == null ? View.GONE : View.VISIBLE}"
            android:text="@{model.content}"
            android:gravity="center"
            android:textAppearance="@style/Subheadline"
            android:textColor="@color/neutral600"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="내용입니다!"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_content"
            >

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_negative"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:contentPaddingBottom="13dp"
                app:contentPaddingTop="13dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingLeft="8dp"
                app:text="@{model.negativeText}"
                app:textColor="@color/neutral800"
                app:cardBackgroundColor="@color/neutral000"
                app:pressedColor="@color/neutral200"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp"
                />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_positive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:text="@{model.positiveText}"
                app:contentPaddingBottom="13dp"
                app:contentPaddingTop="13dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingLeft="8dp"
                app:cardBackgroundColor="@color/neutral000"
                app:pressedColor="@color/danger100"
                app:textColor='@color/danger500'
                app:borderColor='@color/danger500'
                app:borderWidth="1dp"
                />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>