<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <import type="android.view.View" />
        <variable name="isSelectionMode" type="Boolean" />
        <variable name="isAnySelected" type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_bottom_sheet_neutral000_radius28"
        android:paddingBottom="24dp">

        <View
            android:id="@+id/view_handle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:background="@color/neutral200"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:text="승인 대기 명단"
            android:textAppearance="@style/Title3Bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/view_handle" />

        <com.umc.presentation.component.UButton
            android:id="@+id/btn_select_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:contentPaddingLeft="8dp"
            app:contentPaddingRight="8dp"
            app:contentPaddingTop="4dp"
            app:contentPaddingBottom="4dp"
            android:visibility="@{isSelectionMode ? View.GONE : View.VISIBLE}"
            app:prevIcon="@drawable/ic_check_success"
            app:prevIconTint="@color/neutral800"
            app:text="선택 승인하기"
            app:textAppearance="@style/SubheadlineBold"
            app:cardBackgroundColor="@color/neutral000"
            app:textColor="@color/neutral700"
            app:borderWidth="1dp"
            app:borderColor="@color/neutral200"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            android:layout_marginEnd="16dp" />

        <com.umc.presentation.component.UButton
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:contentPaddingLeft="8dp"
            app:contentPaddingRight="8dp"
            app:contentPaddingTop="4dp"
            app:contentPaddingBottom="4dp"
            android:visibility="@{isSelectionMode ? View.VISIBLE : View.GONE}"
            android:enabled="@{isAnySelected}"
            app:text="확인"
            app:cardBackgroundColor="@{isAnySelected ? @color/primary500 : @color/neutral200}"
            app:textColor="@color/neutral000"
            app:textAppearance="@style/SubheadlineBold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            android:layout_marginEnd="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_pending_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>