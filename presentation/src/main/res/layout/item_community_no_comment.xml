<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="com.umc.domain.model.enums.RecruitType" />
        <import type="com.umc.domain.model.enums.ContentType" />
        <import type="com.umc.domain.model.enums.CategoryType" />

        <variable
            name="item"
            type="com.umc.domain.model.community.CommentItem" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/neutral000">

        <ImageView
            android:id="@+id/item_imv"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_comment"
            android:tint="@color/neutral500"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <TextView
            android:id="@+id/item_tv_username"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="@style/Subheadline"
            android:textColor="@color/neutral500"
            android:text="@string/community_detail_please_first_comment"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/item_imv"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            />



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>