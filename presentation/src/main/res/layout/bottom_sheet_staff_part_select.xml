<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:paddingBottom="24dp">

        <include
            android:id="@+id/layout_top"
            layout="@layout/include_bottom_sheet_top_bar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/layout_top">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="파트 선택"
                android:textAppearance="@style/Title3Bold"
                android:textColor="@color/neutral800" />

            <TextView
                android:id="@+id/text_all_option"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:paddingVertical="16dp"
                android:text="전체"
                android:textAppearance="@style/Body"
                android:textColor="@color/neutral800" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:background="@color/neutral100" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_part_list"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
