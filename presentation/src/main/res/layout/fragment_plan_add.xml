                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="16dp"
                                app:text="@{vm.uiState.lateEndDateText}"
                                app:backgroundColor="@color/neutral000"
                                app:pressedColor="@color/neutral300"
                                app:borderColor="@color/neutral200"
                                app:borderWidth="1dp"
                                app:textAppearance="@style/SubheadlineBold"
                                app:textColor="@color/neutral500"
                                app:layout_constraintEnd_toStartOf="@id/planadd_chip_late_end_time"
                                app:layout_constraintTop_toBottomOf="@id/planadd_divider_attendance_2"
                                app:layout_constraintBottom_toBottomOf="parent"/>

                            <com.umc.presentation.component.UChip
                                android:id="@+id/planadd_chip_late_end_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="16dp"
                                android:layout_marginTop="16dp"
                                app:text="@{vm.uiState.lateEndTimeText}"
                                app:backgroundColor="@color/neutral000"
                                app:pressedColor="@color/neutral300"
                                app:borderColor="@color/neutral200"
                                app:borderWidth="1dp"
                                app:textAppearance="@style/SubheadlineBold"
                                app:textColor="@color/neutral500"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/planadd_divider_attendance_2"/>

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <androidx.constraintlayout.widget.Barrier
                        android:id="@+id/planadd_barrier_bottom_content"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
