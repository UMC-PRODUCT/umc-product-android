                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_marginTop="16dp"
                                app:text="@{vm.uiState.onTimeEndDateText}"
                                app:backgroundColor="@color/neutral000"
                                app:pressedColor="@color/neutral300"
                                app:borderColor="@color/neutral200"
                                app:borderWidth="1dp"
                                app:textAppearance="@style/SubheadlineBold"
                                app:textColor="@color/neutral500"
                                app:layout_constraintEnd_toStartOf="@id/planadd_chip_on_time_end_time"
                                app:layout_constraintTop_toBottomOf="@id/planadd_divider_attendance_1"/>

                            <com.umc.presentation.component.UChip
                                android:id="@+id/planadd_chip_on_time_end_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="16dp"
                                android:layout_marginTop="16dp"
                                app:text="@{vm.uiState.onTimeEndTimeText}"
                                app:backgroundColor="@color/neutral000"
                                app:pressedColor="@color/neutral300"
                                app:borderColor="@color/neutral200"
                                app:borderWidth="1dp"
                                app:textAppearance="@style/SubheadlineBold"
                                app:textColor="@color/neutral500"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/planadd_divider_attendance_1"/>

                            <!-- 구분선 2 -->
                            <View
                                android:id="@+id/planadd_divider_attendance_2"
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:background="@color/neutral300"
                                android:layout_marginTop="16dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/planadd_chip_on_time_end_date"/>

                            <!-- 지각 인정 -->
                            <TextView
                                android:id="@+id/planadd_tv_late_end"
