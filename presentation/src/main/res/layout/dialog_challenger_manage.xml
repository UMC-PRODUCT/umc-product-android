<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable
            name="model"
            type="com.umc.domain.model.act.challenger.ChallengerManageDialogModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neutral000_radius16"
        android:padding="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_profile_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imv_profile"
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:profileImageUrl="@{model.profileImageUrl}"
                app:strokeWidth="1dp"
                app:strokeColor="@color/neutral200"
                app:shapeAppearanceOverlay="@style/CircleImageAppearance"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@{model.name}"
                android:textAppearance="@style/Title3Bold"
                android:textColor="@color/neutral800"
                android:includeFontPadding="false"
                app:layout_constraintTop_toBottomOf="@id/imv_profile"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="김디자" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_university"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:clickable="false"
                app:text="@{model.university}"
                app:textColor="@color/neutral700"
                app:textAppearance="@style/Caption1Bold"
                app:cardBackgroundColor="@color/neutral000"
                app:borderColor="@color/neutral200"
                app:borderWidth="1dp"
                app:cornerRadius="4dp"
                app:contentPaddingTop="4dp"
                app:contentPaddingBottom="4dp"
                app:contentPaddingLeft="8dp"
                app:contentPaddingRight="8dp"
                app:layout_constraintTop_toTopOf="@id/tv_name"
                app:layout_constraintBottom_toBottomOf="@id/tv_name"
                app:layout_constraintStart_toEndOf="@id/tv_name" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_part"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:clickable="false"
                app:text="@{model.part}"
                app:textColor="@color/primary500"
                app:textAppearance="@style/Caption1Bold"
                app:cardBackgroundColor="@color/primary100"
                app:borderColor="@color/primary200"
                app:borderWidth="1dp"
                app:cornerRadius="4dp"
                app:contentPaddingTop="4dp"
                app:contentPaddingBottom="4dp"
                app:contentPaddingLeft="8dp"
                app:contentPaddingRight="8dp"
                app:layout_constraintTop_toTopOf="@id/tv_name"
                app:layout_constraintBottom_toBottomOf="@id/tv_name"
                app:layout_constraintStart_toEndOf="@id/btn_university" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageView
            android:id="@+id/imv_icon_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_close_big"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layout_default_buttons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:weightSum="3"
            app:layout_constraintTop_toBottomOf="@id/layout_profile_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_warning_view"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:text="@string/challenger_manage_action_warning"
                app:textAppearance="@style/Subheadline"
                app:topIcon="@drawable/ic_error"
                app:contentPaddingTop="10dp"
                app:contentPaddingBottom="10dp"
                app:cardBackgroundColor="@color/neutral000"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_absence_view"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:text="@string/challenger_manage_action_out"
                app:textAppearance="@style/Subheadline"
                app:topIcon="@drawable/ic_block"
                app:contentPaddingTop="10dp"
                app:contentPaddingBottom="10dp"
                app:cardBackgroundColor="@color/neutral000"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_record_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:text="@string/challenger_manage_action_edit_history"
                app:textAppearance="@style/Subheadline"
                app:topIcon="@drawable/ic_setting"
                app:contentPaddingTop="10dp"
                app:contentPaddingBottom="10dp"
                app:cardBackgroundColor="@color/neutral000"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_input_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/layout_default_buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_absence_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_absence_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/challenger_manage_out_reason_title"
                    android:textColor="@color/neutral800"
                    android:textAppearance="@style/HeadlineBold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <com.umc.presentation.component.UTextField
                    android:id="@+id/et_absence_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:placeholderText="@string/challenger_manage_reason_placeholder"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/neutral300"
                    app:layout_constraintTop_toBottomOf="@id/tv_absence_title" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_absence_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:text="@string/challenger_manage_out_confirm"
                    app:cardBackgroundColor="@color/neutral100"
                    app:textColor="@color/neutral400"
                    app:textAppearance="@style/CalloutBold"
                    app:contentPaddingTop="12dp"
                    app:contentPaddingBottom="12dp"
                    app:borderColor="@color/neutral300"
                    app:borderWidth="1dp"
                    app:layout_constraintTop_toBottomOf="@id/et_absence_reason" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_warning_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_warning_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/challenger_manage_warning_reason_title"
                    android:textColor="@color/neutral800"
                    android:textAppearance="@style/HeadlineBold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <com.umc.presentation.component.UTextField
                    android:id="@+id/et_warning_reason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:placeholderText="@string/challenger_manage_reason_placeholder"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/neutral300"
                    app:layout_constraintTop_toBottomOf="@id/tv_warning_title" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_warning_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:text="@string/challenger_manage_warning_confirm"
                    app:cardBackgroundColor="@color/neutral100"
                    app:textColor="@color/neutral400"
                    app:textAppearance="@style/CalloutBold"
                    app:borderColor="@color/neutral300"
                    app:borderWidth="1dp"
                    app:contentPaddingTop="12dp"
                    app:contentPaddingBottom="12dp"
                    app:layout_constraintTop_toBottomOf="@id/et_warning_reason" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/tv_new_badge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_primary100_radius8"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_check_success"
                    app:tint="@color/primary500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/challenger_manage_delete_guide"
                    android:textAppearance="@style/Caption1"
                    android:textColor="@color/primary500" />
            </LinearLayout>
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_history_section"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layout_input_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_history"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_history"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_history_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/challenger_manage_history_title"
                android:textAppearance="@style/Title3Bold"
                app:layout_constraintTop_toTopOf="@id/iv_history"
                app:layout_constraintBottom_toBottomOf="@id/iv_history"
                app:layout_constraintStart_toEndOf="@id/iv_history" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toEndOf="@id/tv_history_label"
                app:layout_constraintTop_toTopOf="parent">

                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_absence_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:text='@{"아웃 " + model.absenceCount}'
                    app:textColor="@color/danger500"
                    app:textAppearance="@style/Caption1Bold"
                    app:cardBackgroundColor="@color/danger100"
                    app:borderColor="@color/danger300"
                    app:borderWidth="1dp"
                    app:cornerRadius="4dp"
                    app:contentPaddingTop="4dp"
                    app:contentPaddingBottom="4dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_warning_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    app:text='@{"경고 " + model.warningCount}'
                    app:textColor="@color/warning500"
                    app:textAppearance="@style/Caption1Bold"
                    app:cardBackgroundColor="@color/warning100"
                    app:borderColor="@color/warning300"
                    app:borderWidth="1dp"
                    app:cornerRadius="4dp"
                    app:contentPaddingTop="4dp"
                    app:contentPaddingBottom="4dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                android:padding="16dp"
                android:overScrollMode="never"
                android:visibility="@{model.history.empty ? View.GONE : View.VISIBLE}"
                app:layout_constraintTop_toBottomOf="@id/tv_history_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:listitem="@layout/item_challenger_history" />

            <LinearLayout
                android:id="@+id/layout_empty_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="30dp"
                android:visibility="@{model.history.empty ? View.VISIBLE : View.GONE}"
                app:layout_constraintTop_toBottomOf="@id/tv_history_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_history"
                    app:tint="@color/neutral500" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="아직 활동 기록이 없습니다"
                    android:textAppearance="@style/Caption1Bold"
                    android:textColor="@color/neutral500" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>