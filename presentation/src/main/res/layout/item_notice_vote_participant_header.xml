<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/text_option_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/SubheadlineBold"
        android:textColor="@color/neutral800"
        app:layout_constraintEnd_toStartOf="@id/text_option_count"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="짜장면" />

    <TextView
        android:id="@+id/text_option_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/FootnoteBold"
        android:textColor="@color/primary500"
        app:layout_constraintBottom_toBottomOf="@id/text_option_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/text_option_title"
        tools:text="2명" />

</androidx.constraintlayout.widget.ConstraintLayout>
