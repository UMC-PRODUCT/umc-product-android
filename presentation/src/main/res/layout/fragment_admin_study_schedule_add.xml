<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.act.study.schedule.AdminActStudyScheduleAddFragment">

    <data>

        <import type="android.view.View" />

        <variable
            name="vm"
            type="com.umc.presentation.ui.act.study.schedule.model.AdminActStudyScheduleAddViewModel" />

        <variable
            name="state"
            type="com.umc.presentation.ui.act.study.schedule.model.AdminActStudyScheduleAddState" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral000"
        android:paddingHorizontal="16dp">


        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_title"
            app:tint="@color/neutral800" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:text="스터디 일정 등록"
            android:textAppearance="@style/Title2Bold"
            android:textColor="@color/neutral800"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <TextView
                    android:id="@+id/tv_study_name_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="스터디명"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_study_name_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/danger500"
                    app:layout_constraintStart_toEndOf="@id/tv_study_name_label"
                    app:layout_constraintTop_toTopOf="@id/tv_study_name_label" />

                <com.umc.presentation.component.UTextField
                    android:id="@+id/et_study_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/neutral000"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_study_name_label"
                    app:placeholderText="스터디명을 입력하세요."
                    app:strokeColor="@color/neutral300"
                    app:strokeWidth="1dp"
                    app:text="@{state.studyName}"
                    app:textAppearance="@style/Subheadline" />


                <TextView
                    android:id="@+id/tv_date_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="일시"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_study_name" />

                <TextView
                    android:id="@+id/tv_date_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/danger500"
                    app:layout_constraintStart_toEndOf="@id/tv_date_label"
                    app:layout_constraintTop_toTopOf="@id/tv_date_label" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_datetime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/neutral000"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_date_label"
                    app:strokeColor="@color/neutral300"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="16dp">


                        <TextView
                            android:id="@+id/tv_start"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="시작"
                            android:textAppearance="@style/Callout"
                            android:textColor="@color/neutral600"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@id/chip_start_date"
                            app:layout_constraintBottom_toBottomOf="@id/chip_start_date"/>

                        <com.umc.presentation.component.UChip
                            android:id="@+id/chip_start_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            app:backgroundColor="@color/neutral000"
                            app:borderColor="@color/neutral200"
                            app:borderWidth="1dp"
                            app:layout_constraintEnd_toStartOf="@id/chip_start_time"
                            app:layout_constraintTop_toTopOf="parent"
                            app:pressedColor="@color/neutral300"
                            app:text="@{state.startDateText}"
                            app:textAppearance="@style/SubheadlineBold"
                            app:textColor="@color/neutral500" />

                        <com.umc.presentation.component.UChip
                            android:id="@+id/chip_start_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            app:backgroundColor="@color/neutral000"
                            app:borderColor="@color/neutral200"
                            app:borderWidth="1dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:pressedColor="@color/neutral300"
                            app:text="@{state.startTimeText}"
                            app:textAppearance="@style/SubheadlineBold"
                            app:textColor="@color/neutral500" />

                        <View
                            android:id="@+id/div1"
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:background="@color/neutral300"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/chip_start_date" />


                        <TextView
                            android:id="@+id/tv_end"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="종료"
                            android:textAppearance="@style/Callout"
                            android:textColor="@color/neutral600"
                            app:layout_constraintTop_toTopOf="@id/chip_end_date"
                            app:layout_constraintBottom_toBottomOf="@id/chip_end_date"
                            app:layout_constraintStart_toStartOf="parent" />

                        <com.umc.presentation.component.UChip
                            android:id="@+id/chip_end_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_marginTop="16dp"
                            app:backgroundColor="@color/neutral000"
                            app:borderColor="@color/neutral200"
                            app:borderWidth="1dp"
                            app:layout_constraintEnd_toStartOf="@id/chip_end_time"
                            app:layout_constraintTop_toBottomOf="@id/div1"
                            app:pressedColor="@color/neutral300"
                            app:text="@{state.endDateText}"
                            app:textAppearance="@style/SubheadlineBold"
                            app:textColor="@color/neutral500" />

                        <com.umc.presentation.component.UChip
                            android:id="@+id/chip_end_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="16dp"
                            android:layout_marginTop="16dp"
                            app:backgroundColor="@color/neutral000"
                            app:borderColor="@color/neutral200"
                            app:borderWidth="1dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/div1"
                            app:pressedColor="@color/neutral300"
                            app:text="@{state.endTimeText}"
                            app:textAppearance="@style/SubheadlineBold"
                            app:textColor="@color/neutral500" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>


                <TextView
                    android:id="@+id/tv_location_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="장소"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/card_datetime" />

                <TextView
                    android:id="@+id/tv_location_required"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="*"
                    android:textAppearance="@style/HeadlineBold"
                    android:textColor="@color/danger500"
                    app:layout_constraintStart_toEndOf="@id/tv_location_label"
                    app:layout_constraintTop_toTopOf="@id/tv_location_label" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="@color/neutral000"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_location_label"
                    app:strokeColor="@color/neutral300"
                    app:strokeWidth="1dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tv_location_value"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text='@{state.locationName.isEmpty() ? @string/home_plan_add_plan_location_placeholder : state.locationName}'
                            android:textAppearance="@style/Subheadline"
                            android:textColor='@{state.locationName.isEmpty() ? @color/neutral400 : @color/neutral800}'
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/iv_location_go"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:id="@+id/iv_location_go"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_arrow_next"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:tint="@color/neutral500" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>


                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/guideline_mid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintGuide_percent="0.5" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_cancel"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginTop="48dp"
                    android:layout_marginEnd="8dp"
                    app:borderColor="@color/neutral300"
                    app:borderWidth="1dp"
                    app:cardBackgroundColor="@color/neutral000"
                    app:cornerRadius="8dp"
                    app:layout_constraintEnd_toStartOf="@id/guideline_mid"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/card_location"
                    app:pressedColor="@color/neutral200"
                    app:text="취소"
                    app:textAppearance="@style/HeadlineBold"
                    app:textColor="@color/neutral800" />


                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_register"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="48dp"
                    android:visibility="@{state.isRegisterOk ? View.VISIBLE : View.GONE}"
                    app:cardBackgroundColor="@color/primary500"
                    app:cornerRadius="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/guideline_mid"
                    app:layout_constraintTop_toBottomOf="@id/card_location"
                    app:pressedColor="@color/primary700"
                    app:text="일정 등록하기"
                    app:textAppearance="@style/HeadlineBold"
                    app:textColor="@color/neutral000" />


                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_register_disabled"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="48dp"
                    android:visibility="@{state.isRegisterOk ? View.GONE : View.VISIBLE}"
                    app:cardBackgroundColor="@color/neutral300"
                    app:cornerRadius="8dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/guideline_mid"
                    app:layout_constraintTop_toBottomOf="@id/card_location"
                    app:pressedColor="@color/neutral300"
                    app:text="일정 등록하기"
                    app:textAppearance="@style/HeadlineBold"
                    app:textColor="@color/neutral000" />

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="64dp"
                    android:layout_marginTop="64dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_register" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
