<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <import type="android.view.View"/>
        <variable name="vm"
            type="com.umc.presentation.ui.act.dialog.BottomSheetRewardEtcViewModel" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:background="@drawable/bg_bottom_sheet_neutral000_radius28"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp"

        >

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/view_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="@color/neutral600"
        app:cardBackgroundColor="@color/neutral600"
        app:cornerRadius="100dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="start"
        android:text="@string/reward_etc_title"
        android:textAppearance="@style/Title3Bold"
        android:textColor="@color/neutral800"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_handle" />

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="start"
            android:text="@string/reward_etc_content"
            android:textAppearance="@style/Subheadline"
            android:textColor="@color/neutral600"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />


        <!--상점-->
        <TextView
            android:id="@+id/tv_reward_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="start"
            android:text="@string/reward"
            android:textAppearance="@style/CalloutBold"
            android:textColor="@color/neutral800"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_content" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cdv_reward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/neutral100"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_reward_title">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            >

            <ImageView
                android:id="@+id/btn_reward_minus_off"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_reward_minus_off"
                android:visibility="@{vm.uiState.reward > 0 ? View.INVISIBLE : View.VISIBLE}"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <ImageView
                android:id="@+id/btn_reward_minus_on"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_reward_minus"
                android:visibility="@{vm.uiState.reward > 0 ? View.VISIBLE : View.INVISIBLE}"
                android:onClick="@{()->vm.minusReward()}"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tv_reward_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{String.valueOf(vm.uiState.reward)}"
                android:textAppearance="@style/Title3Bold"
                android:textColor="@color/success500"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_reward_minus_on"/>

            <ImageView
                android:id="@+id/btn_reward_plus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_reward_plus"
                android:onClick="@{()->vm.plusReward()}"
                android:layout_marginStart="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_reward_score"/>


        </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


        <!--벌점-->
        <TextView
            android:id="@+id/tv_punish_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="start"
            android:text="@string/punish"
            android:textAppearance="@style/CalloutBold"
            android:textColor="@color/neutral800"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cdv_reward" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cdv_punish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/neutral100"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_punish_title">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                >

                <ImageView
                    android:id="@+id/btn_punish_minus_off"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_reward_minus_off"
                    android:visibility="@{vm.uiState.punish > 0 ? View.INVISIBLE : View.VISIBLE}"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ImageView
                    android:id="@+id/btn_punish_minus_on"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_reward_minus"
                    android:visibility="@{vm.uiState.punish > 0 ? View.VISIBLE : View.INVISIBLE}"
                    android:onClick="@{()->vm.minusPunish()}"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_punish_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{String.valueOf(vm.uiState.punish)}"
                    android:textAppearance="@style/Title3Bold"
                    android:textColor="@color/danger500"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_punish_minus_on"/>

                <ImageView
                    android:id="@+id/btn_punish_plus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_reward_plus"
                    android:onClick="@{()->vm.plusPunish()}"
                    android:layout_marginStart="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@id/tv_punish_score"/>


            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>


        <!--사유-->
        <TextView
            android:id="@+id/tv_reason_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="start"
            android:text="@string/reward_etc_reason"
            android:textAppearance="@style/CalloutBold"
            android:textColor="@color/neutral800"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cdv_punish" />

        <com.umc.presentation.component.UTextField
            android:id="@+id/textfield_reason"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="16dp"
            android:background="@color/neutral000"
            app:cardBackgroundColor="@color/neutral000"
            android:gravity="top|start"
            app:strokeWidth="1dp"
            app:strokeColor="@color/neutral300"
            app:layout_constraintTop_toBottomOf="@id/tv_reason_title"
            app:layout_constraintBottom_toTopOf="@id/btn_submit"
            app:layout_constraintVertical_bias="0"
            app:placeholderText="@string/reward_etc_placeholder"
            app:textAppearance="@style/Subheadline"
            app:text="@{vm.uiState.description}"
            app:onTextChanged="@{vm::onTextChanged}"
            />


        <!--등록 버튼-->
        <com.umc.presentation.component.UButton
            android:id="@+id/btn_submit"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:onClick="@{()->vm.submitReward()}"
            android:visibility="@{vm.uiState.submitOk == true ? View.VISIBLE : View.GONE}"
            app:cardBackgroundColor="@color/primary500"
            app:cornerRadius="8dp"
            app:pressedColor="@color/primary700"
            app:text="@string/reward_submit"
            app:textAppearance="@style/HeadlineBold"
            app:textColor="@color/neutral000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />

        <com.umc.presentation.component.UButton
            android:id="@+id/btn_submit_cancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:visibility="@{vm.uiState.submitOk == false ? View.VISIBLE : View.GONE}"
            app:cardBackgroundColor="@color/neutral300"
            app:cornerRadius="8dp"
            app:pressedColor="@color/neutral300"
            app:text="@string/reward_submit"
            app:textAppearance="@style/HeadlineBold"
            app:textColor="@color/neutral000"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>