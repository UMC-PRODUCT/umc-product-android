<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.community.search.PostSearchFragment">

    <data>

        <variable
            name="vm"
            type="com.umc.presentation.ui.community.search.PostSearchViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral000"
        android:paddingHorizontal="16dp"
        android:paddingBottom="64dp"
        >

        <com.umc.presentation.component.UTextField
            android:id="@+id/search_textfield"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/neutral000"
            android:layout_marginEnd="8dp"
            app:strokeColor="@color/neutral300"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/neutral000"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/search_btn_cancel"
            app:placeholderText="@string/community_search_placehold"
            app:textAppearance="@style/Subheadline"
            app:imeAction="@{android.view.inputmethod.EditorInfo.IME_ACTION_SEARCH}"
            app:onImeAction="@{(actionId, text) -> vm.onImeAction(actionId, text)}"
            />

        <TextView
            android:id="@+id/search_btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/CalloutBold"
            android:textColor="@color/neutral800"
            android:text="@string/cancel"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:paddingVertical="13dp"
            android:paddingHorizontal="8dp"
            app:layout_constraintTop_toTopOf="@id/search_textfield"
            app:layout_constraintBottom_toBottomOf="@id/search_textfield"
            app:layout_constraintEnd_toEndOf="parent"
            />



    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>