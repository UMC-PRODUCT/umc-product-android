<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />

        <variable
            name="item"
            type="com.umc.presentation.ui.act.study.submit.model.AdminActStudySubmitItemUiModel" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/neutral000"
        app:cornerRadius="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="76dp"
            android:padding="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_profile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile_default"
                app:shapeAppearanceOverlay="@style/CircleImageAppearance"
                app:strokeWidth="1dp"
                app:strokeColor="@color/neutral200"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />



            <LinearLayout
                android:id="@+id/right_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="7dp"
                    android:visibility='@{(item.markStatus == null || item.isBest) ? View.GONE : View.VISIBLE}'
                    app:buttonElevation="0"
                    app:contentPaddingBottom="4dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp"
                    app:contentPaddingTop="4dp"
                    app:cornerRadius="4dp"
                    app:markStatusStyle='@{item.markStatus}'
                    app:markStatusText='@{item.markStatus}'
                    app:textAppearance="@style/Caption1Bold"
                    app:textColor='@{item.markStatus == "FAIL" ? @color/danger700 : @color/success700}'
                    tools:text="Pass"
                    tools:visibility="visible" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/btn_best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:visibility='@{item.isBest ? View.VISIBLE : View.GONE}'
                    app:cardBackgroundColor="@color/warning100"
                    app:buttonElevation="0"
                    app:contentPaddingBottom="4dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp"
                    app:contentPaddingTop="4dp"
                    app:cornerRadius="4dp"
                    app:text="Best"
                    app:textAppearance="@style/Caption1Bold"
                    app:textColor="@color/warning500"
                    tools:visibility="visible" />

                <ImageView
                    android:id="@+id/iv_arrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_next"
                    android:tint="@color/neutral500"
                    tools:ignore="ContentDescription" />

            </LinearLayout>



            <LinearLayout
                android:id="@+id/layout_text_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical"
                app:layout_constraintStart_toEndOf="@id/iv_profile"
                app:layout_constraintEnd_toStartOf="@id/right_container"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.5">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='@{item.nickname + "(" + item.name + ")"}'
                        android:textAppearance="@style/BodyBold"
                        android:textColor="@color/neutral800"
                        tools:text="홍길동(닉네임)" />

                    <com.umc.presentation.component.UButton
                        android:id="@+id/ub_part"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:clickable="false"
                        android:focusable="false"
                        app:buttonElevation="0"
                        app:cornerRadius="6dp"
                        app:contentPaddingLeft="8dp"
                        app:contentPaddingRight="8dp"
                        app:contentPaddingTop="2dp"
                        app:contentPaddingBottom="2dp"
                        app:textAppearance="@style/Caption1Bold"
                        app:text="@{item.partLabel}"
                        app:backgroundColor="@color/neutral000"
                        app:borderWidth="1dp"
                        app:borderColor="@color/neutral200"
                        app:textColor="@color/neutral700"
                        tools:text="iOS" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_school"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text='@{item.schoolName}'
                        android:textAppearance="@style/Caption1"
                        android:textColor="@color/neutral500"
                        tools:text="중앙대" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="|"
                        android:textAppearance="@style/Caption1"
                        android:textColor="@color/neutral500" />

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:text='@{item.studyTitle}'
                        android:textAppearance="@style/Caption1"
                        android:textColor="@color/primary500"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="SwiftUI 클론 코딩" />
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>