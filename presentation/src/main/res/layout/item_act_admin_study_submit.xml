<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="item"
            type="com.umc.presentation.ui.act.study.submit.model.AdminActStudySubmitItemUiModel" />
    </data>


    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/neutral000"
        app:cornerRadius="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_profile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_person_inset"
                android:scaleType="centerInside"
                app:shapeAppearanceOverlay="@style/CircleImageAppearance"
                app:strokeWidth="1dp"
                app:strokeColor="@color/neutral100"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text='@{item.name + "(" + item.nickname + ")"}'
                android:textAppearance="@style/BodyBold"
                android:textColor="@color/neutral800"
                app:layout_constraintStart_toEndOf="@id/iv_profile"
                app:layout_constraintTop_toTopOf="@id/iv_profile"
                tools:text="홍길동(닉네임)" />

            <com.umc.presentation.component.UButton
                android:id="@+id/ub_part"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:clickable="false"
                android:focusable="false"
                app:buttonElevation="0"
                app:cornerRadius="6dp"
                app:contentPaddingLeft="10dp"
                app:contentPaddingRight="10dp"
                app:contentPaddingTop="4dp"
                app:contentPaddingBottom="4dp"
                app:textAppearance="@style/Caption1Bold"
                app:text="@{item.partLabel}"
                app:backgroundColor="@color/neutral000"
                app:borderWidth="1dp"
                app:borderColor="@color/neutral200"
                app:textColor="@color/neutral700"
                app:layout_constraintStart_toEndOf="@id/tv_name"
                app:layout_constraintBottom_toBottomOf="@id/tv_name"
                tools:text="iOS" />

            <TextView
                android:id="@+id/tv_sub"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text='@{item.weekText + " | " + item.studyTitle}'
                android:textAppearance="@style/Caption1"
                android:textColor="@color/primary500"
                app:layout_constraintStart_toStartOf="@id/tv_name"
                app:layout_constraintTop_toBottomOf="@id/tv_name"
                app:layout_constraintEnd_toStartOf="@id/layout_swipe_hint"
                tools:text="1주차 | SwiftUI 플로팅 코딩" />



            <LinearLayout
                android:id="@+id/layout_swipe_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_swipe"
                    app:tint="@color/neutral300"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="스와이프"
                    android:textAppearance="@style/Caption2"
                    android:textColor="@color/neutral300" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>
