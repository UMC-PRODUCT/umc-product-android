<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <import type="com.umc.domain.model.enums.AdminSessionStatus" />
        <variable
            name="uiModel"
            type="com.umc.presentation.ui.act.check.AdminSessionUIModel" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="8dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/neutral000"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="24dp">

            <TextView
                android:id="@+id/tv_admin_session_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@{uiModel.session.title}"
                android:textAppearance="@style/Title3Bold"
                android:textColor="@color/neutral800"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constrainedWidth="true"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btn_admin_session_status"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="4주차 정기세션 제목" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_admin_session_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="12dp"
                app:adminStatusStyle="@{uiModel.session.status}"
                app:buttonElevation="0"
                app:contentPaddingBottom="2dp"
                app:contentPaddingLeft="8dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingTop="2dp"
                app:cornerRadius="4dp"
                app:layout_constrainedWidth="true"
                app:layout_constraintStart_toEndOf="@+id/tv_admin_session_title"
                app:layout_constraintEnd_toStartOf="@id/btn_admin_change_location"
                app:layout_constraintTop_toTopOf="@+id/tv_admin_session_title"
                app:layout_constraintBottom_toBottomOf="@+id/tv_admin_session_title"
                app:text="@{uiModel.session.status.text}"
                app:textAppearance="@style/Caption1Bold"
                tools:text="진행 중" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_admin_change_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="@{uiModel.session.status == AdminSessionStatus.COMPLETED ? View.GONE : View.VISIBLE}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:backgroundColor="@color/neutral000"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp"
                app:prevIcon="@drawable/ic_location_update"
                app:cornerRadius="8dp"
                app:contentPaddingLeft="8dp"
                app:contentPaddingRight="8dp"
                app:contentPaddingTop="4dp"
                app:contentPaddingBottom="4dp"
                app:text="@string/admin_check_change_location"
                app:textAppearance="@style/SubheadlineBold"
                app:textColor="@color/neutral700" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_admin_session_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_admin_session_title">

                <ImageView
                    android:id="@+id/iv_admin_calendar"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendar_color"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_admin_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@{uiModel.session.date}"
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_admin_calendar"
                    app:layout_constraintStart_toEndOf="@+id/iv_admin_calendar"
                    app:layout_constraintTop_toTopOf="@+id/iv_admin_calendar"
                    tools:text="2024.03.23 (토)" />

                <ImageView
                    android:id="@+id/iv_admin_clock"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_clock"
                    app:layout_constraintBottom_toBottomOf="@+id/tv_admin_date"
                    app:layout_constraintStart_toEndOf="@+id/tv_admin_date"
                    app:layout_constraintTop_toTopOf="@+id/tv_admin_date" />

                <TextView
                    android:id="@+id/tv_admin_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text='@{String.format("%s - %s", uiModel.session.startTime, uiModel.session.endTime)}'
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_admin_clock"
                    app:layout_constraintStart_toEndOf="@+id/iv_admin_clock"
                    app:layout_constraintTop_toTopOf="@+id/iv_admin_clock"
                    tools:text="14:00 - 18:00" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/layout_admin_stats_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_neutral000_radius8"
                android:paddingVertical="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_admin_session_info">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_checklist" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_check_stats_attendance_rate"
                        android:textAppearance="@style/Caption1"
                        android:textColor="@color/neutral600" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text='@{String.format("%d(%%)", uiModel.session.attendanceRate)}'
                        android:textAppearance="@style/SubheadlineBold"
                        android:textColor="@color/neutral800"
                        tools:text="85(%)" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical"
                    android:background="@color/neutral200" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_person_outline" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_check_stats_attendance_count"
                        android:textAppearance="@style/Caption1"
                        android:textColor="@color/neutral600" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text='@{String.format("%d/%d(명)", uiModel.session.attendedChallengers, uiModel.session.totalChallengers)}'
                        android:textAppearance="@style/SubheadlineBold"
                        android:textColor="@color/neutral800"
                        tools:text="34/40(명)" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center_vertical"
                    android:background="@color/neutral200" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_hourglass" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_check_stats_pending_count"
                        android:textAppearance="@style/Caption1"
                        android:textColor="@color/neutral600" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text='@{String.format("%d(명)", uiModel.session.pendingCount)}'
                        android:textAppearance="@style/SubheadlineBold"
                        android:textColor="@color/neutral800"
                        tools:text="3(명)" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/layout_admin_stats_group">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_admin_pending_list_trigger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_primary500_radius12"
                    android:padding="16dp"
                    android:visibility='@{uiModel.session.pendingCount > 0 ? View.VISIBLE : View.GONE}'>

                    <ImageView
                        android:id="@+id/iv_admin_btn_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_person_color"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/primary500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/admin_check_pending_list_trigger"
                        android:textAppearance="@style/SubheadlineBold"
                        android:textColor="@color/neutral800"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/iv_admin_btn_icon"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_next"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:id="@+id/layout_admin_completed_box"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_neutral000_radius8"
                    android:gravity="center"
                    android:paddingVertical="14dp"
                    android:layout_marginTop="20dp"
                    android:visibility="@{(uiModel.session.status == AdminSessionStatus.COMPLETED &amp;&amp; uiModel.session.pendingCount == 0) ? View.VISIBLE : View.GONE}">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_check_success"
                        app:tint="@color/success500" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/admin_check_completed_message"
                        android:textAppearance="@style/SubheadlineBold"
                        android:textColor="@color/neutral600" />
                </LinearLayout>
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</layout>