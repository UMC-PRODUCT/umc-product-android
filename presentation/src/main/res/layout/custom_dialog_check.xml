<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="android.view.View" />
        <variable
            name="model"
            type="com.umc.presentation.component.UCheckDialogModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neutral000_radius16"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/imv_icon_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_close_big"
            android:padding="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@{model.title}"
            android:gravity="center"
            android:textAppearance="@style/Title3Bold"
            android:textColor="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/imv_icon_close"
            app:layout_constraintBottom_toBottomOf="@id/imv_icon_close"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="출석 사유 작성" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@{model.subtitle}"
            android:gravity="center"
            android:textAppearance="@style/Subheadline"
            android:textColor="@color/neutral600"
            app:layout_constraintTop_toBottomOf="@id/imv_icon_close"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="위치 인증이 어려운 경우 사유를 작성하여\n출석을 요청할 수 있습니다.\n(예: GPS 오류, 지각, 개인 사정 등)" />

        <TextView
            android:id="@+id/tv_reason_display"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_rectangle_accent100_stroke_accent300_radius8"
            android:padding="16dp"
            android:text="@{model.reason}"
            android:textAppearance="@style/Body"
            android:textColor="@color/neutral800"
            android:visibility="@{model.isWriteMode ? View.GONE : View.VISIBLE}"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="“지하철 연착으로 인해 5분 정도 늦을 것 같습니다. 죄송합니다!”" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_input_group"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:visibility="@{model.isWriteMode ? View.VISIBLE : View.GONE}"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_input_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사유 입력"
                android:textAppearance="@style/HeadlineBold"
                android:textColor="@color/neutral800"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <com.umc.presentation.component.UTextField
                android:id="@+id/et_reason_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:placeholderText="사유를 입력하세요."
                app:cornerRadius="8dp"
                app:strokeColor="@color/neutral300"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/tv_input_label"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/layout_input_group"
            app:layout_goneMarginTop="32dp"
            app:layout_constraintBottom_toBottomOf="parent">
            <com.umc.presentation.component.UButton
                android:id="@+id/btn_negative"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:visibility="@{model.isWriteMode ? View.VISIBLE : View.GONE}"
                app:text="취소"
                app:textColor="@color/neutral800"
                app:cardBackgroundColor="@color/neutral000"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp"
                app:contentPaddingTop="13dp"
                app:contentPaddingBottom="13dp" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_positive"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:text="@{model.positiveText}"
                app:textColor="@color/neutral000"
                app:cardBackgroundColor="@color/accent500"
                app:contentPaddingTop="13dp"
                app:contentPaddingBottom="13dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>