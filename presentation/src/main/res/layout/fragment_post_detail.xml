<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.community.detail.PostDetailFragment">

    <data>

        <import type="android.view.View"/>

        <variable
            name="vm"
            type="com.umc.presentation.ui.community.detail.PostDetailViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral000"
        >

        <!-- 상단 바 -->
        <ImageView
            android:id="@+id/postdetail_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:layout_marginStart="16dp"
            android:onClick="@{()->vm.moveBackPressed()}"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/postdetail_tv_big_title"
            app:layout_constraintBottom_toBottomOf="@id/postdetail_tv_big_title"
            app:layout_constraintStart_toStartOf="parent"
            />

        <TextView
            android:id="@+id/postdetail_tv_big_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Title2Bold"
            android:textColor="@color/neutral800"
            android:text="@string/community_detail_title"
            android:layout_marginVertical="18dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/postdetail_btn_back"
            />

        <ImageView
            android:id="@+id/postdetail_btn_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_menu_kebab"
            android:layout_marginEnd="16dp"
            android:onClick="@{()->vm.onClickOpenMenu()}"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/postdetail_tv_big_title"
            app:layout_constraintBottom_toBottomOf="@id/postdetail_tv_big_title"
            app:layout_constraintEnd_toEndOf="parent"
            />

        <!--메뉴 버튼-->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/postdetail_layout_kebab_menu"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:visibility="@{vm.uiState.isMenuVisible == true ? View.VISIBLE : View.GONE}"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/neutral000"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/postdetail_btn_menu"
            app:layout_constraintEnd_toEndOf="@id/postdetail_btn_menu">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:id="@+id/layout_menu_report"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="@{vm.uiState.isAuthor ? View.GONE : View.VISIBLE}">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:onClick="@{() -> vm.onClickReportPost()}"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_error_filled"
                            app:tint="@color/danger500" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="신고하기"
                            android:textAppearance="@style/Subheadline"
                            android:textColor="@color/danger500" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_next_small"
                            app:tint="@color/danger500" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_menu_edit_delete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="@{vm.uiState.isAuthor ? View.VISIBLE : View.GONE}">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="@{() -> vm.onClickEditPost()}"
                        >
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_edit"
                            app:tint="@color/neutral800"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="수정하기"
                            android:textColor="@color/neutral800"
                            android:textAppearance="@style/Subheadline"/>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_next_small"
                            app:tint="@color/neutral800"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/neutral200" android:layout_marginVertical="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="?attr/selectableItemBackground"
                        android:onClick="@{() -> vm.onClickDeletePost()}"
                        >
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@drawable/ic_trash_can"
                            app:tint="@color/danger500"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_height="wrap_content"
                            android:text="삭제하기"
                            android:textColor="@color/danger500"
                            android:textAppearance="@style/Subheadline"/>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_next_small"
                            app:tint="@color/danger500"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>



        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/postdetail_rcv"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/postdetail_tv_big_title"
            app:layout_constraintBottom_toTopOf="@id/postdetail_layout_comment" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/postdetail_layout_comment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/neutral000"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.umc.presentation.component.UTextField
                android:id="@+id/postdetail_edt_comment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="댓글을 입력해주세요."
                android:background="@color/neutral000"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/neutral300"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/neutral000"
                app:layout_constraintStart_toStartOf="parent"
                app:placeholderText="@string/community_detail_placeholder"
                app:textAppearance="@style/Body"
                app:layout_constraintEnd_toStartOf="@id/postdetail_imv_send" />

            <ImageView
                android:id="@+id/postdetail_imv_send"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_send"
                android:tint="@color/neutral300"
                android:scaleType="centerInside"
                android:onClick="@{()->vm.onClickCommentAdd()}"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/postdetail_edt_comment"
                app:layout_constraintBottom_toBottomOf="@id/postdetail_edt_comment" />
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>