<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.community.detail.PostDetailFragment">

    <data>

        <variable
            name="vm"
            type="com.umc.presentation.ui.community.detail.PostDetailViewModel" />

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/neutral000"
        >

        <!-- 상단 바 -->
        <ImageView
            android:id="@+id/postdetail_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:layout_marginStart="16dp"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/postdetail_tv_big_title"
            app:layout_constraintBottom_toBottomOf="@id/postdetail_tv_big_title"
            app:layout_constraintStart_toStartOf="parent"
            />

        <TextView
            android:id="@+id/postdetail_tv_big_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Title2Bold"
            android:textColor="@color/neutral800"
            android:text="@string/home_plan_detail_title"
            android:layout_marginVertical="18dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/postdetail_btn_back"
            />

        <ImageView
            android:id="@+id/postdetail_btn_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_menu_kebab"
            android:layout_marginEnd="16dp"
            app:tint="@color/neutral800"
            app:layout_constraintTop_toTopOf="@id/postdetail_tv_big_title"
            app:layout_constraintBottom_toBottomOf="@id/postdetail_tv_big_title"
            app:layout_constraintEnd_toEndOf="parent"
            />


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/postdetail_rcv"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/postdetail_tv_big_title"
            app:layout_constraintBottom_toTopOf="@id/postdetail_layout_comment" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/postdetail_layout_comment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/neutral000"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.umc.presentation.component.UTextField
                android:id="@+id/postdetail_edt_comment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="댓글을 입력해주세요."
                android:background="@color/neutral000"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/neutral300"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/neutral000"
                app:layout_constraintStart_toStartOf="parent"
                app:placeholderText="@string/community_detail_placeholder"
                app:textAppearance="@style/Body"
                app:layout_constraintEnd_toStartOf="@id/postdetail_imv_send" />

            <ImageView
                android:id="@+id/postdetail_imv_send"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_send"
                android:tint="@color/neutral300"
                android:scaleType="centerInside"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/postdetail_edt_comment"
                app:layout_constraintBottom_toBottomOf="@id/postdetail_edt_comment" />
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


</layout>