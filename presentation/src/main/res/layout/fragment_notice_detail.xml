<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.notice.detail.NoticeDetailFragment">

    <data>

        <import type="android.view.View" />

        <import type="com.umc.domain.model.enums.VoteCondition" />

        <variable
            name="vm"
            type="com.umc.presentation.ui.notice.detail.NoticeDetailViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/text_check_unconfirmed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:onClick="@{()->vm.onClickShowBottomSheet()}"
            android:text="@string/notice_detail_unconfirmed_people_check"
            android:textAppearance="@style/Footnote"
            android:textColor="@color/neutral600"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:indeterminate="false"
            android:max="100"
            android:progress="@{vm.uiState.readStatistics != null ? (int)(vm.uiState.readStatistics.readRate * 100) : 0}"
            app:indicatorColor="@color/success500"
            app:layout_constraintBottom_toTopOf="@id/text_check_unconfirmed"
            app:trackColor="@color/neutral200"
            app:trackCornerRadius="999dp"
            app:trackThickness="6dp" />

        <ImageView
            android:id="@+id/image_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginBottom="21dp"
            android:src="@drawable/ic_check_success"
            app:layout_constraintBottom_toTopOf="@id/progressBar"
            app:layout_constraintStart_toStartOf="@id/progressBar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/notice_detail_confirmed_people_check"
            android:textAppearance="@style/HeadlineBold"
            android:textColor="@color/neutral800"
            app:layout_constraintBottom_toBottomOf="@id/image_check"
            app:layout_constraintStart_toEndOf="@id/image_check"
            app:layout_constraintTop_toTopOf="@id/image_check" />

        <TextView
            android:id="@+id/text_all_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text='@{vm.uiState.readStatistics != null ? String.valueOf(vm.uiState.readStatistics.totalCount) : "0"}'
            android:textAppearance="@style/Body"
            android:textColor="@color/neutral800"
            app:layout_constraintBottom_toBottomOf="@id/image_check"
            app:layout_constraintEnd_toEndOf="@id/progressBar"
            app:layout_constraintTop_toTopOf="@id/image_check" />

        <TextView
            android:id="@+id/text_now_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text='@{vm.uiState.readStatistics != null ? String.valueOf(vm.uiState.readStatistics.readCount) + "/" : "0/"}'
            android:textAppearance="@style/Body"
            android:textColor="@color/success500"
            app:layout_constraintBottom_toBottomOf="@id/image_check"
            app:layout_constraintEnd_toStartOf="@id/text_all_check"
            app:layout_constraintTop_toTopOf="@id/image_check" />

        <View
            android:id="@+id/view_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="15dp"
            android:background="@color/neutral200"
            app:layout_constraintBottom_toTopOf="@id/image_check" />


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@id/view_divider"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/neutral000"
                android:paddingBottom="32dp">

                <ImageView
                    android:id="@+id/image_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:onClick="@{()->vm.onClickBackPressed()}"
                    android:padding="12dp"
                    android:src="@drawable/ic_back"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/notice_tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/home_notice_title"
                    android:textAppearance="@style/Title2Bold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintBottom_toBottomOf="@id/image_back"
                    app:layout_constraintStart_toEndOf="@id/image_back"
                    app:layout_constraintTop_toTopOf="@id/image_back" />

                <ImageView
                    android:id="@+id/notice_btn_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_menu_kebab"
                    android:visibility="@{vm.uiState.isCurrentUserMember ? View.GONE : View.VISIBLE}"
                    android:onClick="@{()->vm.onClickMenu()}"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/postdetail_layout_kebab_menu"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:visibility="@{vm.uiState.isCurrentUserMember || !vm.uiState.isMenuVisible ? View.GONE : View.VISIBLE}"
                    app:cardBackgroundColor="@color/neutral000"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    app:layout_constraintEnd_toEndOf="@id/notice_btn_menu"
                    app:layout_constraintTop_toBottomOf="@id/notice_btn_menu">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <LinearLayout
                            android:id="@+id/layout_menu_edit_delete"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="?attr/selectableItemBackground"
                                android:gravity="center_vertical"
                                android:onClick="@{() -> vm.onClickEditPost()}"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/ic_edit"
                                    app:tint="@color/neutral800" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:text="수정하기"
                                    android:textAppearance="@style/Subheadline"
                                    android:textColor="@color/neutral800" />

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_next_small"
                                    app:tint="@color/neutral800" />
                            </LinearLayout>

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:layout_marginVertical="4dp"
                                android:background="@color/neutral200" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="?attr/selectableItemBackground"
                                android:gravity="center_vertical"
                                android:onClick="@{() -> vm.onClickDeletePost()}"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/ic_trash_can"
                                    app:tint="@color/danger500" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:layout_weight="1"
                                    android:text="삭제하기"
                                    android:textAppearance="@style/Subheadline"
                                    android:textColor="@color/danger500" />

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_next_small"
                                    app:tint="@color/danger500" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!--                <com.umc.presentation.component.UButton-->
                <!--                    android:id="@+id/ubutton_must_read"-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_marginStart="24dp"-->
                <!--                    android:layout_marginTop="24dp"-->
                <!--                    android:visibility="@{vm.uiState.detail.mustRead ? View.VISIBLE : View.GONE}"-->
                <!--                    app:buttonElevation="0"-->
                <!--                    app:cardBackgroundColor="@color/warning500"-->
                <!--                    app:contentPaddingBottom="2dp"-->
                <!--                    app:contentPaddingLeft="8dp"-->
                <!--                    app:contentPaddingRight="8dp"-->
                <!--                    app:contentPaddingTop="2dp"-->
                <!--                    app:cornerRadius="4dp"-->
                <!--                    app:layout_constraintStart_toStartOf="parent"-->
                <!--                    app:layout_constraintTop_toBottomOf="@id/image_back"-->
                <!--                    app:text="필독"-->
                <!--                    app:textAppearance="@style/Caption1Bold"-->
                <!--                    app:textColor="@color/neutral000" />-->

                <!--                <Space-->
                <!--                    android:id="@+id/space_between"-->
                <!--                    android:layout_width="4dp"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    app:layout_constraintStart_toEndOf="@id/ubutton_must_read"-->
                <!--                    app:layout_constraintTop_toTopOf="@id/ubutton_must_read" />-->

                <com.umc.presentation.component.UButton
                    android:id="@+id/ubutton_central"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="24dp"
                    android:visibility="@{vm.uiState.detail.targetInfo != null ? View.VISIBLE : View.GONE}"
                    app:buttonElevation="0"
                    app:cardBackgroundColor="@color/neutral200"
                    app:contentPaddingBottom="2dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp"
                    app:contentPaddingTop="2dp"
                    app:cornerRadius="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/image_back"
                    app:text="중앙"
                    app:textAppearance="@style/Caption1Bold"
                    app:textColor="@color/neutral700" />

                <Space
                    android:id="@+id/space_central_chapter"
                    android:layout_width="4dp"
                    android:layout_height="wrap_content"
                    android:visibility="@{vm.uiState.detail.targetInfo.targetChapterId != null ? View.VISIBLE : View.GONE}"
                    app:layout_constraintStart_toEndOf="@id/ubutton_central"
                    app:layout_constraintTop_toTopOf="@id/ubutton_central" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/ubutton_chapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="@{(vm.uiState.detail.targetInfo.targetChapterId != null) ? View.VISIBLE : View.GONE}"
                    app:buttonElevation="0"
                    app:cardBackgroundColor="@color/neutral200"
                    app:contentPaddingBottom="2dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp"
                    app:contentPaddingTop="2dp"
                    app:cornerRadius="4dp"
                    app:layout_constraintStart_toEndOf="@id/space_central_chapter"
                    app:layout_constraintTop_toTopOf="@id/ubutton_central"
                    app:text="지부"
                    app:textAppearance="@style/Caption1Bold"
                    app:textColor="@color/neutral700" />

                <Space
                    android:id="@+id/space_chapter_school"
                    android:layout_width="4dp"
                    android:layout_height="wrap_content"
                    android:visibility="@{(vm.uiState.detail.targetInfo.targetSchoolId != null) ? View.VISIBLE : View.GONE}"
                    app:layout_constraintStart_toEndOf="@id/ubutton_chapter"
                    app:layout_constraintTop_toTopOf="@id/ubutton_chapter" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/ubutton_school"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="@{(vm.uiState.detail.targetInfo.targetSchoolId != null) ? View.VISIBLE : View.GONE}"
                    app:buttonElevation="0"
                    app:cardBackgroundColor="@color/primary100"
                    app:contentPaddingBottom="2dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp"
                    app:contentPaddingTop="2dp"
                    app:cornerRadius="4dp"
                    app:layout_constraintStart_toEndOf="@id/space_chapter_school"
                    app:layout_constraintTop_toTopOf="@id/ubutton_central"
                    app:text="학교"
                    app:textAppearance="@style/Caption1Bold"
                    app:textColor="@color/primary600" />

                <Space
                    android:id="@+id/space_school_part"
                    android:layout_width="4dp"
                    android:layout_height="wrap_content"
                    android:visibility="@{(!vm.uiState.detail.targetInfo.targetParts.empty) ? View.VISIBLE : View.GONE}"
                    app:layout_constraintStart_toEndOf="@id/ubutton_school"
                    app:layout_constraintTop_toTopOf="@id/ubutton_school" />

                <com.umc.presentation.component.UButton
                    android:id="@+id/ubutton_part"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="@{(!vm.uiState.detail.targetInfo.targetParts.empty) ? View.VISIBLE : View.GONE}"
                    app:buttonElevation="0"
                    app:cardBackgroundColor="@color/success100"
                    app:contentPaddingBottom="2dp"
                    app:contentPaddingLeft="8dp"
                    app:contentPaddingRight="8dp"
                    app:contentPaddingTop="2dp"
                    app:cornerRadius="4dp"
                    app:layout_constraintStart_toEndOf="@id/space_school_part"
                    app:layout_constraintTop_toTopOf="@id/ubutton_central"
                    app:text="@{vm.uiState.detail.targetInfo.targetParts[0]}"
                    app:textAppearance="@style/Caption1Bold"
                    app:textColor="@color/success700" />

                <TextView
                    android:id="@+id/text_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="64dp"
                    android:text="@{vm.uiState.detail.title}"
                    android:textAppearance="@style/Title2Bold"
                    android:textColor="@color/neutral800"
                    app:layout_constraintTop_toBottomOf="@id/image_back"
                    tools:text="[필독] 12기 활동 " />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/image_profile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"
                    app:layout_constraintStart_toStartOf="@id/text_title"
                    app:layout_constraintTop_toBottomOf="@id/text_title"
                    app:shapeAppearanceOverlay="@style/CircleImageAppearance"
                    app:strokeColor="@color/neutral200"
                    app:strokeWidth="1dp" />

                <TextView
                    android:id="@+id/text_nickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@{vm.uiState.authorNickname}"
                    android:textAppearance="@style/Subheadline"
                    android:textColor="@color/neutral800"
                    app:layout_constraintBottom_toBottomOf="@id/image_profile"
                    app:layout_constraintStart_toEndOf="@id/image_profile"
                    app:layout_constraintTop_toTopOf="@id/image_profile"
                    tools:text="운영진" />

                <TextView
                    android:id="@+id/text_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@{vm.uiState.formattedCreatedAt}"
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintStart_toStartOf="@id/text_title"
                    app:layout_constraintTop_toBottomOf="@id/image_profile"
                    tools:text="2026.01.01" />

                <TextView
                    android:id="@+id/text_divider1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:text="|"
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintBottom_toBottomOf="@id/text_date"
                    app:layout_constraintStart_toEndOf="@id/text_date"
                    app:layout_constraintTop_toTopOf="@id/text_date" />

                <TextView
                    android:id="@+id/text_view_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text='@{"조회수 " + vm.uiState.detail.viewCount}'
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintStart_toEndOf="@id/text_divider1"
                    app:layout_constraintTop_toBottomOf="@id/image_profile"
                    tools:text="조회수 100" />

                <TextView
                    android:id="@+id/text_divider2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="8dp"
                    android:text="|"
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintBottom_toBottomOf="@id/text_view_count"
                    app:layout_constraintStart_toEndOf="@id/text_view_count"
                    app:layout_constraintTop_toTopOf="@id/text_view_count" />

                <TextView
                    android:id="@+id/text_receiver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@{vm.uiState.formattedTargetInfo}"
                    android:textAppearance="@style/Footnote"
                    android:textColor="@color/neutral600"
                    app:layout_constraintStart_toEndOf="@id/text_divider2"
                    app:layout_constraintTop_toBottomOf="@id/image_profile"
                    tools:text="수신대상: 12기/전체" />

                <TextView
                    android:id="@+id/text_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="32dp"
                    android:paddingBottom="24dp"
                    android:text="@{vm.uiState.detail.content}"
                    android:textAppearance="@style/Body"
                    android:textColor="@color/neutral800"
                    app:layout_constraintTop_toBottomOf="@id/text_view_count"
                    tools:text="안녕하세요. 운영진입니다." />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_link"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_rect_neutral100_radius12"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="11dp"
                    android:visibility="@{vm.uiState.detail.links == null || vm.uiState.detail.links.empty ? View.GONE : View.VISIBLE}"
                    app:layout_constraintTop_toBottomOf="@id/text_content">

                    <ImageView
                        android:id="@+id/image_link_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_blog_link"
                        android:tint="@color/primary500"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/text_link_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/notice_detail_about_link_title"
                        android:textAppearance="@style/HeadlineBold"
                        android:textColor="@color/neutral800"
                        app:layout_constraintStart_toEndOf="@id/image_link_title"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_link"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginEnd="8dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@{vm.uiState.detail.links.size() == 0 ? &quot;&quot; : vm.uiState.detail.links.get(0).url}"
                        android:textAppearance="@style/Footnote"
                        android:textColor="@color/neutral600"
                        app:layout_constraintEnd_toStartOf="@id/image_arrow"
                        app:layout_constraintStart_toEndOf="@id/image_link_title"
                        app:layout_constraintTop_toBottomOf="@id/text_link_title"
                        tools:text="https://example.com/guideline" />

                    <ImageView
                        android:id="@+id/image_arrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="6dp"
                        android:src="@drawable/ic_calendar_arrow_right"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_vote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_rect_neutral100_radius12"
                    android:padding="16dp"
                    android:visibility="@{vm.uiState.detail.vote == null || vm.uiState.detail.vote.title.empty ? View.GONE : View.VISIBLE}"
                    app:layout_constraintTop_toBottomOf="@id/layout_link">

                    <ImageView
                        android:id="@+id/image_vote_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_vote"
                        android:tint="@color/primary500"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/text_vote_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@{vm.uiState.detail.vote.title}"
                        android:textAppearance="@style/HeadlineBold"
                        android:textColor="@color/neutral800"
                        app:layout_constraintBottom_toBottomOf="@id/image_vote_title"
                        app:layout_constraintStart_toEndOf="@id/image_vote_title"
                        app:layout_constraintTop_toTopOf="@id/image_vote_title"
                        tools:text="회식 메뉴 투표" />

                    <com.umc.presentation.component.UButton
                        android:id="@+id/ubutton_vote_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonElevation="0"
                        app:cardBackgroundColor="@color/primary500"
                        app:contentPaddingBottom="4dp"
                        app:contentPaddingLeft="8dp"
                        app:contentPaddingRight="8dp"
                        app:contentPaddingTop="4dp"
                        app:cornerRadius="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:text="진행중"
                        app:textAppearance="@style/Caption1Bold"
                        app:textColor="@color/neutral000" />
                    <!-- app:text="@{vm.uiState.detail.vote.status}"-->

                    <TextView
                        android:id="@+id/text_vote_condition"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@{vm.uiState.formattedVoteCondition}"
                        android:textAppearance="@style/Footnote"
                        android:textColor="@color/neutral600"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/image_vote_title" />


                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_vote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:overScrollMode="never"
