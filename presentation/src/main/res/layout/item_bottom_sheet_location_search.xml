<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:paddingVertical="8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >

    <TextView
        android:id="@+id/item_tv_location_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/BodyBold"
        android:textColor="@color/neutral800"
        android:text="서울역"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/item_btn_select"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/item_tv_location_content"
        />

    <TextView
        android:id="@+id/item_tv_location_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/Footnote"
        android:textColor="@color/neutral600"
        android:text="서울특별시 용산구 한강대로 405"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/item_btn_select"
        app:layout_constraintTop_toBottomOf="@id/item_tv_location_title"
        app:layout_constraintBottom_toBottomOf="parent"
        />

    <com.umc.presentation.component.UButton
        android:id="@+id/item_btn_select"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/neutral000"
        app:pressedColor="@color/neutral200"
        app:borderWidth="1dp"
        app:borderColor="@color/neutral800"
        app:text="@string/select"
        app:textAppearance="@style/SubheadlineBold"
        app:textColor="@color/neutral800"
        app:buttonElevation="0"
        app:contentPaddingBottom="13dp"
        app:contentPaddingTop="13dp"
        app:contentPaddingLeft="8dp"
        app:contentPaddingRight="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>