<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">


    <data>
        <variable
            name="item"
            type="com.umc.presentation.ui.act.study.submit.model.AdminActStudySubmitItemUiModel" />
    </data>


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_neutral000_radius16"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_close_big"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="베스트 워크북 선정"
            android:textAppearance="@style/Title3Bold"
            android:textColor="@color/neutral800"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/iv_close"
            app:layout_constraintBottom_toBottomOf="@id/iv_close"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <TextView
            android:id="@+id/tv_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text='@{@string/admin_best_desc(item.nickname)}'
            android:textAppearance="@style/Subheadline"
            android:textColor="@color/neutral600"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <TextView
            android:id="@+id/tv_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="추천사유(커뮤니티 공개용)"
            android:textAppearance="@style/HeadlineBold"
            android:textColor="@color/neutral800"
            app:layout_constraintTop_toBottomOf="@id/tv_desc"
            app:layout_constraintStart_toStartOf="parent" />


        <com.umc.presentation.component.UTextField
            android:id="@+id/et_reason"
            android:layout_width="0dp"
            android:layout_height="112dp"
            android:layout_marginTop="8dp"
            android:gravity="start|top"
            app:cornerRadius="12dp"
            app:strokeColor="@color/neutral300"
            app:strokeWidth="1dp"
            app:placeholderText="이 스터디를 추천하는 이유를 작성하세요."
            app:layout_constraintTop_toBottomOf="@id/tv_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/et_reason"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:text="취소"
                app:textColor="@color/neutral800"
                app:cardBackgroundColor="@color/neutral000"
                app:borderColor="@color/neutral300"
                app:borderWidth="1dp"
                app:contentPaddingTop="13dp"
                app:contentPaddingBottom="13dp" />


            <com.umc.presentation.component.UButton
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                app:text="선정하기"
                app:textColor="@color/neutral000"
                app:cardBackgroundColor="@color/warning500"
                app:contentPaddingTop="13dp"
                app:contentPaddingBottom="13dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
