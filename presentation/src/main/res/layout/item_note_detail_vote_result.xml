<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_rectangle_neutral000_stroke_neutral300_radius8"
        android:layout_marginBottom="16dp"
        android:padding="16dp">

        <!-- 옵션 이름 -->
        <TextView
            android:id="@+id/text_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Subheadline"
            android:textColor="@color/neutral800"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/image_check"
            tools:text="삼겹살"/>

        <!-- 체크마크 (내가 선택한 항목일 때만 표시) -->
        <ImageView
            android:id="@+id/image_check"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_check_success"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@id/text_percentage"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/primary500" />

        <!-- 퍼센트 -->
        <TextView
            android:id="@+id/text_percentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/SubheadlineBold"
            android:textColor="@color/primary500"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="53.3%"/>

        <!-- 프로그레스 바 -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_bar"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:max="100"
            app:indicatorColor="@color/primary500"
            app:trackColor="@color/neutral200"
            app:trackCornerRadius="999dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_name"
            tools:progress="53"/>

        <!-- 투표 수 -->
        <TextView
            android:id="@+id/text_vote_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/Caption1"
            android:textColor="@color/neutral500"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progress_bar"
            tools:text="16명"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
