<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@drawable/bg_neutral000_radius16">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="그룹 정보 수정"
            android:textAppearance="@style/SubheadlineBold"
            android:textColor="@color/neutral900"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/iv_close" />

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/neutral500"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/tv_group_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="그룹 이름"
            android:textAppearance="@style/Caption1"
            android:textColor="@color/neutral700"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent" />


        <com.umc.presentation.component.UTextField
            android:id="@+id/et_group_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/neutral300"
            app:strokeWidth="1dp"
            app:focusStrokeColor="@color/primary500"
            app:placeholderText="예: React 실습 A팀"
            app:placeholderTextColor="@color/neutral400"
            app:textAppearance="@style/Body"
            app:textColor="@color/neutral800"
            app:layout_constraintTop_toBottomOf="@id/tv_group_name_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />



        <TextView
            android:id="@+id/tv_part_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="소속파트"
            android:textAppearance="@style/Caption1"
            android:textColor="@color/neutral700"
            app:layout_constraintTop_toBottomOf="@id/et_group_name"
            app:layout_constraintStart_toStartOf="parent" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_part_dropdown"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_neutral000_radius8"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_part_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_selected_part"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Web"
                android:textAppearance="@style/CalloutBold"
                android:textColor="@color/neutral800"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_arrow"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/iv_arrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_dropdown_down"
                app:tint="@color/neutral500"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_part_dropdown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/neutral000"
            app:strokeColor="@color/neutral200"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/cl_part_dropdown"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_part_dropdown"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:overScrollMode="never"/>
        </com.google.android.material.card.MaterialCardView>


        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/card_part_dropdown"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                app:text="취소"
                app:cardBackgroundColor="@color/neutral000"
                app:borderColor="@color/neutral200"
                app:borderWidth="1dp"
                app:textColor="@color/neutral700" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <com.umc.presentation.component.UButton
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                app:text="수정 완료"
                app:cardBackgroundColor="@color/primary500"
                app:textColor="@color/neutral000" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
